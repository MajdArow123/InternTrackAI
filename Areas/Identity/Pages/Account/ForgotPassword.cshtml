@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
}

<div class="auth-header">
    <h1 class="auth-title">Reset your password</h1>
    <p class="auth-subtitle">Enter your email address and we'll send you a link to reset it</p>
</div>

@if (ViewData.ModelState.IsValid && Model.ForgotPasswordConfirmation)
{
    <div class="alert alert-success" role="alert">
        <h4 class="alert-heading">Check your email</h4>
        <p>We've sent a password reset link to your email address. Please check your inbox (and spam folder) for the reset link.</p>
    </div>
    <p class="auth-switch">
        <a asp-page="./Login">Back to sign in</a>
    </p>
}
else
{
    <form method="post" novalidate>
        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.SelectMany(v => v.Errors).Any())
        {
            <div class="auth-alert">
                <span>⚠</span>
                <div asp-validation-summary="ModelOnly"></div>
            </div>
        }

        <div class="auth-field">
            <label asp-for="Input.Email" class="form-label">Email address</label>
            <input asp-for="Input.Email" class="form-control auth-input"
                   type="email" placeholder="you@example.com" autocomplete="email" />
            <span asp-validation-for="Input.Email" class="auth-error"></span>
        </div>

        <button type="submit" class="btn auth-submit-btn">Send reset link</button>
    </form>

    <p class="auth-switch">
        Remember your password?
        <a asp-page="./Login">Sign in</a>
    </p>
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
