@page
@model InternTrackAI.Areas.Identity.Pages.Account.Manage.ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="container py-4" style="max-width:700px;">

    <nav class="breadcrumb-nav" aria-label="breadcrumb">
        <ol class="breadcrumb-list">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li><a asp-page="./Index">Account Settings</a></li>
            <li>Change Password</li>
        </ol>
    </nav>

    <div class="page-header">
        <div>
            <h2>Change Password</h2>
            <p class="sub">Choose a strong password to keep your account secure</p>
        </div>
    </div>

    @if (Model.StatusMessage != null)
    {
        <div class="alert alert-dismissible fade show py-2 mb-3 profile-success-alert" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="form-card">
        <form method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size:.85rem;"></div>

            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Input.OldPassword" class="form-label">Current password</label>
                    <input asp-for="Input.OldPassword" class="form-control" type="password"
                           placeholder="••••••••" autocomplete="current-password" />
                    <span asp-validation-for="Input.OldPassword" class="text-danger" style="font-size:.8rem;"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="Input.NewPassword" class="form-label">New password</label>
                    <input asp-for="Input.NewPassword" class="form-control" type="password"
                           placeholder="At least 6 characters" autocomplete="new-password" />
                    <span asp-validation-for="Input.NewPassword" class="text-danger" style="font-size:.8rem;"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="Input.ConfirmPassword" class="form-label">Confirm new password</label>
                    <input asp-for="Input.ConfirmPassword" class="form-control" type="password"
                           placeholder="••••••••" autocomplete="new-password" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger" style="font-size:.8rem;"></span>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-dark px-4">Update Password</button>
                <a asp-page="./Index" class="btn btn-outline-secondary px-4">Cancel</a>
            </div>
        </form>
    </div>

</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
