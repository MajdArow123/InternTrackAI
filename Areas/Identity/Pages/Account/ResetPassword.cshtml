@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset password";
}

<div class="auth-header">
    <h1 class="auth-title">Set a new password</h1>
    <p class="auth-subtitle">Enter your email and a new password</p>
</div>

@if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.SelectMany(v => v.Errors).Any())
{
    <div class="auth-alert">
        <span>⚠</span>
        <div asp-validation-summary="ModelOnly"></div>
    </div>
}

<form method="post" novalidate>
    <input type="hidden" asp-for="Input.Code" />

    <div class="auth-field">
        <label asp-for="Input.Email" class="form-label">Email address</label>
        <input asp-for="Input.Email" class="form-control auth-input"
               type="email" placeholder="you@example.com" autocomplete="email" />
        <span asp-validation-for="Input.Email" class="auth-error"></span>
    </div>

    <div class="auth-field">
        <label asp-for="Input.Password" class="form-label">New password</label>
        <input asp-for="Input.Password" class="form-control auth-input"
               type="password" placeholder="••••••••" autocomplete="new-password" />
        <span asp-validation-for="Input.Password" class="auth-error"></span>
    </div>

    <div class="auth-field">
        <label asp-for="Input.ConfirmPassword" class="form-label">Confirm password</label>
        <input asp-for="Input.ConfirmPassword" class="form-control auth-input"
               type="password" placeholder="••••••••" autocomplete="new-password" />
        <span asp-validation-for="Input.ConfirmPassword" class="auth-error"></span>
    </div>

    <button type="submit" class="btn auth-submit-btn">Reset password</button>
</form>

<p class="auth-switch">
    <a asp-page="./Login">Back to sign in</a>
</p>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
