@model InternTrackAI.Models.ViewModels.DashboardViewModel
@using InternTrackAI.Models.Enums

@{
    ViewData["Title"] = "Dashboard";

    string BadgeClass(ApplicationStatus s) => s switch
    {
        ApplicationStatus.Saved     => "badge-saved",
        ApplicationStatus.Applied   => "badge-applied",
        ApplicationStatus.Interview => "badge-interview",
        ApplicationStatus.Offer     => "badge-offer",
        ApplicationStatus.Rejected  => "badge-rejected",
        _                           => ""
    };

    string StatusIcon(ApplicationStatus s) => s switch
    {
        ApplicationStatus.Saved     => "<svg class=\"status-icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z\"/></svg>",
        ApplicationStatus.Applied   => "<svg class=\"status-icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"22\" y1=\"2\" x2=\"11\" y2=\"13\"/><polygon points=\"22 2 15 22 11 13 2 9 22 2\"/></svg>",
        ApplicationStatus.Interview => "<svg class=\"status-icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\"/><line x1=\"16\" y1=\"2\" x2=\"16\" y2=\"6\"/><line x1=\"8\" y1=\"2\" x2=\"8\" y2=\"6\"/><line x1=\"3\" y1=\"10\" x2=\"21\" y2=\"10\"/></svg>",
        ApplicationStatus.Offer     => "<svg class=\"status-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\" stroke=\"none\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>",
        ApplicationStatus.Rejected  => "<svg class=\"status-icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><line x1=\"15\" y1=\"9\" x2=\"9\" y2=\"15\"/><line x1=\"9\" y1=\"9\" x2=\"15\" y2=\"15\"/></svg>",
        _                           => ""
    };

    string Initials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}".ToUpper()
            : name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }

    int maxCompanyCount = Model.TopCompanies.Any() ? Model.TopCompanies.Max(kv => kv.Value) : 1;
}

<div class="container py-4">

    <!-- Breadcrumb -->
    <nav class="breadcrumb-nav" aria-label="breadcrumb">
        <ol class="breadcrumb-list">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li>Dashboard</li>
        </ol>
    </nav>

    <!-- Page header -->
    <div class="page-header">
        <div>
            <h2>Dashboard</h2>
            <p class="sub">Your internship search at a glance</p>
        </div>
        <a asp-controller="JobApplications" asp-action="Create" class="btn btn-dark">
            + Add Application
        </a>
    </div>

    <!-- Deadline & follow-up alerts -->
    @if (Model.UpcomingDeadlines.Any() || Model.FollowUpSuggestions.Any())
    {
        <div class="alert-section">
            @if (Model.UpcomingDeadlines.Any())
            {
                <div class="alert-card alert-card--amber mb-2">
                    <div class="alert-card-title">
                        @Model.UpcomingDeadlines.Count deadline@(Model.UpcomingDeadlines.Count == 1 ? "" : "s") in the next 3 days
                    </div>
                    @foreach (var app in Model.UpcomingDeadlines)
                    {
                        var daysLeft = (app.Deadline!.Value.Date - DateTime.UtcNow.Date).Days;
                        var urgency  = daysLeft == 0 ? "Today" : daysLeft == 1 ? "Tomorrow" : $"In {daysLeft} days";
                        <div class="alert-item">@app.CompanyName &mdash; @app.RoleTitle &mdash; @urgency</div>
                    }
                </div>
            }
            @if (Model.FollowUpSuggestions.Any())
            {
                <div class="alert-card alert-card--blue">
                    <div class="alert-card-title">Follow-up opportunities</div>
                    @foreach (var app in Model.FollowUpSuggestions)
                    {
                        var days = (DateTime.UtcNow.Date - app.DateApplied!.Value.Date).Days;
                        <div class="alert-item">@app.CompanyName &mdash; @app.RoleTitle &mdash; applied @days days ago</div>
                    }
                </div>
            }
        </div>
    }

    <!-- Stat cards -->
    <div class="stats-grid mb-4">
        <div class="stat-card stat-card-total anim-fade-up anim-d1">
            <div class="stat-number" data-count="@Model.TotalApplications">@Model.TotalApplications</div>
            <div class="stat-label">Total</div>
        </div>
        @{int delay = 2;}
        @foreach (var status in Enum.GetValues<ApplicationStatus>())
        {
            var count = Model.StatusCounts.GetValueOrDefault(status, 0);
            <div class="stat-card stat-card-@status.ToString().ToLower() anim-fade-up anim-d@(delay)">
                <div class="stat-number" data-count="@count">@count</div>
                <div class="stat-label">@status</div>
            </div>
            delay = Math.Min(delay + 1, 6);
        }
    </div>

    <!-- Analytics strip -->
    @if (Model.TotalApplications > 0)
    {
        <div class="analytics-strip anim-fade-up anim-d4">
            <div class="analytics-card">
                <div class="analytics-card-label">Success Rate</div>
                <div class="analytics-card-value @(Model.SuccessRate >= 10 ? "value-success" : "")">
                    @Model.SuccessRate<span style="font-size:1rem;font-weight:600">%</span>
                </div>
                <div class="analytics-card-sub">
                    @Model.StatusCounts.GetValueOrDefault(ApplicationStatus.Offer, 0) offer@(Model.StatusCounts.GetValueOrDefault(ApplicationStatus.Offer, 0) == 1 ? "" : "s") from @Model.TotalApplications application@(Model.TotalApplications == 1 ? "" : "s")
                </div>
            </div>

            @if (Model.TopCompanies.Any())
            {
                <div class="analytics-card" style="flex:2;min-width:240px">
                    <div class="analytics-card-label">Top Companies</div>
                    <div class="top-companies-list mt-1">
                        @foreach (var kv in Model.TopCompanies)
                        {
                            var pct = maxCompanyCount > 0 ? (int)(kv.Value * 100.0 / maxCompanyCount) : 0;
                            <div class="top-company-row">
                                <span class="top-company-name">@kv.Key</span>
                                <div class="top-company-bar-wrap">
                                    <div class="top-company-bar" style="width:@pct%"></div>
                                </div>
                                <span class="top-company-count">@kv.Value</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }

    <!-- Recent applications -->
    <div class="app-table-wrapper anim-fade-up anim-d4">
        <div class="card-header-clean">
            <h5>Recent Applications</h5>
            <a asp-controller="JobApplications" asp-action="Index"
               class="btn btn-sm btn-outline-secondary" style="font-size:.78rem;border-radius:6px">
                View All
            </a>
        </div>

        @if (!Model.RecentApplications.Any())
        {
            <div class="empty-state-illustrated">
                <svg class="empty-illustration" viewBox="0 0 120 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="25" y="22" width="70" height="68" rx="6" class="empty-illu-bg" fill="#eef2ff"/>
                    <rect x="40" y="14" width="40" height="16" rx="5" class="empty-illu-top" fill="#c7d2fe"/>
                    <rect x="35" y="14" width="50" height="10" rx="5" fill="#c7d2fe"/>
                    <line x1="40" y1="48" x2="80" y2="48" class="empty-illu-line" stroke="#c7d2fe" stroke-width="3.5" stroke-linecap="round"/>
                    <line x1="40" y1="60" x2="72" y2="60" class="empty-illu-line" stroke="#c7d2fe" stroke-width="3.5" stroke-linecap="round"/>
                    <line x1="40" y1="72" x2="62" y2="72" class="empty-illu-line" stroke="#e0e7ff" stroke-width="3.5" stroke-linecap="round"/>
                </svg>
                <p class="empty-state-title">No applications yet</p>
                <p class="empty-state-desc">Start tracking your internship search and see your progress here.</p>
                <a asp-controller="JobApplications" asp-action="Create" class="btn btn-dark btn-sm">
                    Add your first one
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th class="ps-4">Company</th>
                            <th>Role</th>
                            <th class="d-none d-md-table-cell">Mode</th>
                            <th>Status</th>
                            <th class="d-none d-sm-table-cell">Deadline</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in Model.RecentApplications)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="company-avatar">@Initials(app.CompanyName)</span>
                                        <span class="company-name">@app.CompanyName</span>
                                    </div>
                                </td>
                                <td class="role-name">@app.RoleTitle</td>
                                <td class="text-muted d-none d-md-table-cell">@app.WorkMode</td>
                                <td>
                                    <span class="status-badge @BadgeClass(app.Status)">
                                        @Html.Raw(StatusIcon(app.Status)) @app.Status
                                    </span>
                                </td>
                                <td class="text-muted d-none d-sm-table-cell">
                                    @(app.Deadline.HasValue ? app.Deadline.Value.ToString("MMM d, yyyy") : "—")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

</div>

@section Scripts {
<script>
(function () {
    function easeOutQuart(t) { return 1 - Math.pow(1 - t, 4); }

    document.querySelectorAll('.stat-number[data-count]').forEach(function (el) {
        var target = parseInt(el.dataset.count, 10);
        if (isNaN(target) || target === 0) return;
        var start = null;
        var duration = 850;
        function step(ts) {
            if (!start) start = ts;
            var p = Math.min((ts - start) / duration, 1);
            el.textContent = Math.round(easeOutQuart(p) * target);
            if (p < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
    });
})();
</script>
}
