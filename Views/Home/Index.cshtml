@{
    ViewData["Title"] = "Home";
}

<!-- Hero -->
<section class="hero-section text-center">
    <div class="hero-blob hero-blob-1"></div>
    <div class="hero-blob hero-blob-2"></div>

    <div class="container hero-content">
        <div class="hero-eyebrow anim-fade-up anim-d1">
            Your internship command center
        </div>

        <h1 class="hero-title anim-fade-up anim-d2">
            Land your<br><span class="highlight">dream internship.</span>
        </h1>

        <p class="hero-subtitle anim-fade-up anim-d3">
            Track every application, deadline, and interview in one clean dashboard.
            Stop losing track &mdash; start landing offers.
        </p>

        <div class="hero-cta-group anim-fade-up anim-d4">
            <a asp-controller="Home" asp-action="Dashboard" class="btn btn-hero-primary">
                Open Dashboard &rarr;
            </a>
            <a asp-controller="JobApplications" asp-action="Create" class="btn btn-hero-secondary">
                Add Application
            </a>
        </div>

        <!-- Product preview mockup -->
        <div class="hero-preview anim-fade-up anim-d5">
            <div class="hero-preview-bar">
                <span class="hero-preview-dot"></span>
                <span class="hero-preview-dot"></span>
                <span class="hero-preview-dot"></span>
                <span class="hero-preview-bar-title">InternTrackAI &mdash; Dashboard</span>
            </div>
            <div class="hero-preview-body">
                <div class="hero-preview-stats">
                    <div class="hero-preview-stat">
                        <span class="hero-preview-stat-num hero-preview-stat-num--total">12</span>
                        <span class="hero-preview-stat-label">Total</span>
                    </div>
                    <div class="hero-preview-stat">
                        <span class="hero-preview-stat-num hero-preview-stat-num--applied">4</span>
                        <span class="hero-preview-stat-label">Applied</span>
                    </div>
                    <div class="hero-preview-stat">
                        <span class="hero-preview-stat-num hero-preview-stat-num--interview">3</span>
                        <span class="hero-preview-stat-label">Interview</span>
                    </div>
                    <div class="hero-preview-stat">
                        <span class="hero-preview-stat-num hero-preview-stat-num--offer">2</span>
                        <span class="hero-preview-stat-label">Offer</span>
                    </div>
                </div>
                <div class="hero-preview-rows">
                    <div class="hero-preview-row">
                        <span class="hero-preview-avatar">ST</span>
                        <span class="hero-preview-company">Stripe <span class="hero-preview-role">Backend Engineering Intern</span></span>
                        <span class="hero-preview-badge hero-preview-badge--interview">Interview</span>
                    </div>
                    <div class="hero-preview-row">
                        <span class="hero-preview-avatar">ME</span>
                        <span class="hero-preview-company">Meta <span class="hero-preview-role">Data Science Intern</span></span>
                        <span class="hero-preview-badge hero-preview-badge--offer">Offer</span>
                    </div>
                    <div class="hero-preview-row">
                        <span class="hero-preview-avatar">SH</span>
                        <span class="hero-preview-company">Shopify <span class="hero-preview-role">Full-Stack Engineering Intern</span></span>
                        <span class="hero-preview-badge hero-preview-badge--applied">Applied</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features -->
<section class="section-spacer">
    <div class="container">
        <div class="text-center mb-4 anim-fade-up">
            <p class="text-muted small fw-semibold text-uppercase ls-wide mb-1" style="letter-spacing:.08em">Why InternTrackAI</p>
            <h2 style="font-size:1.65rem;font-weight:800;letter-spacing:-.025em">Everything you need, nothing you don&rsquo;t.</h2>
        </div>

        <div class="feature-grid">
            <div class="feature-card anim-fade-up anim-d2">
                <div class="feature-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><line x1="7" y1="9" x2="17" y2="9"/><line x1="7" y1="13" x2="14" y2="13"/><line x1="7" y1="17" x2="11" y2="17"/></svg>
                </div>
                <h5>Track Everything</h5>
                <p>Company, role, location, deadline, salary &mdash; every detail logged in one spot.</p>
            </div>
            <div class="feature-card anim-fade-up anim-d3">
                <div class="feature-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="20" x2="6" y2="14"/><line x1="12" y1="20" x2="12" y2="9"/><line x1="18" y1="20" x2="18" y2="4"/></svg>
                </div>
                <h5>Status at a Glance</h5>
                <p>Color-coded stages from Saved to Offer so you always know where things stand.</p>
            </div>
            <div class="feature-card anim-fade-up anim-d4">
                <div class="feature-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M9 16l1.8 1.8L15 14"/></svg>
                </div>
                <h5>Never Miss a Deadline</h5>
                <p>Deadlines front and center so you apply before the window closes.</p>
            </div>
        </div>

        <div class="divider"></div>

        <div class="text-center anim-fade-up anim-d2">
            <p class="text-muted mb-3" style="font-size:.9rem">Ready to get organized?</p>
            <a asp-controller="JobApplications" asp-action="Index" class="btn btn-dark px-4">
                View All Applications &rarr;
            </a>
        </div>
    </div>
</section>
