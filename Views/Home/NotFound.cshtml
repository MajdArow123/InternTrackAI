@{
    ViewData["Title"] = "Page Not Found";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5" style="max-width:640px;">
    <div class="form-card text-center" style="padding:3rem 2rem;">
        <div style="font-size:3rem;font-weight:800;color:var(--accent);line-height:1;margin-bottom:.5rem;">404</div>
        <h2 style="font-size:1.4rem;font-weight:700;margin-bottom:.75rem;">Page not found</h2>
        <p class="text-muted mb-4" style="font-size:.92rem;line-height:1.6;">
            The page you are looking for does not exist or may have been moved.
            Check the URL or return to the dashboard.
        </p>
        <div class="d-flex gap-3 justify-content-center">
            <a asp-controller="Home" asp-action="Dashboard" class="btn btn-dark px-4">Go to Dashboard</a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary px-4">Home</a>
        </div>
    </div>
</div>
