@model InternTrackAI.Models.JobApplication

@{
    ViewData["Title"] = "Add Application";
}

<div class="container py-4" style="max-width: 760px;">

    <div class="page-header">
        <div>
            <h2>Add Application</h2>
            <p class="sub">Log a new internship you&rsquo;re tracking</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">&larr; Back</a>
    </div>

    <!-- AI Analyzer Panel -->
    <div class="analyzer-card" id="analyzerCard">
        <div class="analyzer-header" id="analyzerToggle">
            <div class="analyzer-header-left">
                <div class="analyzer-icon">AI</div>
                <div>
                    <h6>AI Job Analyzer</h6>
                    <p>Paste a job description or a job posting URL to auto-fill the form</p>
                </div>
            </div>
            <button type="button" class="analyzer-toggle-btn" id="analyzerToggleBtn">
                Open Analyzer
            </button>
        </div>

        <div class="analyzer-body" id="analyzerBody">
            <textarea class="analyzer-textarea" id="analyzerTextarea"
                      placeholder="Paste a job posting URL (e.g. https://jobs.lever.co/...) or the full job description text — company, role, requirements, salary, location.&#10;&#10;The AI will extract key details and fill the form automatically." rows="6"></textarea>

            <div class="d-flex align-items-center gap-2 mt-2">
                <button type="button" class="analyzer-submit" id="analyzeBtn">
                    Analyze with AI
                </button>
                <span class="analyzer-model-tag">GPT-4o mini</span>
            </div>

            <div class="analyzer-result" id="analyzerResult" hidden></div>
            <div class="analyzer-error"  id="analyzerError"  hidden></div>
            <div id="inlineMatchWrap" hidden>
                <div class="inline-match-card" id="inlineMatchCard"></div>
            </div>
        </div>
    </div>

    @if (ViewBag.DuplicateWarning == true)
    {
        <div class="duplicate-warning mb-3" id="duplicateWarning">
            <div class="d-flex align-items-start gap-2">
                <div class="flex-1">
                    <strong>Possible duplicate</strong> — you already have an application for
                    <strong>@Model.CompanyName</strong> &mdash; <strong>@Model.RoleTitle</strong>.
                    Review your existing applications or save anyway if this is intentional.
                </div>
            </div>
            <div class="mt-2 d-flex gap-2">
                <button type="button" class="btn btn-sm btn-dark" id="saveAnywayBtn">Save Anyway</button>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Back to Applications</a>
            </div>
        </div>
    }

    <!-- Application form -->
    <form asp-action="Create" method="post" id="appForm">
        <input type="hidden" name="forceCreate" id="forceCreate" value="false" />

        <!-- Core info -->
        <div class="form-card mb-3">
            <p class="form-section-title">Core Info</p>
            <div class="row g-3">
                <div class="col-sm-6">
                    <label asp-for="CompanyName" class="form-label">Company</label>
                    <input asp-for="CompanyName" class="form-control" placeholder="e.g. Stripe" />
                    <span asp-validation-for="CompanyName" class="text-danger" style="font-size:.78rem"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="RoleTitle" class="form-label">Role Title</label>
                    <input asp-for="RoleTitle" class="form-control" placeholder="e.g. Software Engineering Intern" />
                    <span asp-validation-for="RoleTitle" class="text-danger" style="font-size:.78rem"></span>
                </div>
                <div class="col-sm-6">
                    <label asp-for="Location" class="form-label">Location <span class="text-muted fw-normal">(optional)</span></label>
                    <input asp-for="Location" class="form-control" placeholder="e.g. San Francisco, CA" />
                </div>
                <div class="col-sm-6">
                    <label asp-for="JobLink" class="form-label">Job Link <span class="text-muted fw-normal">(optional)</span></label>
                    <input asp-for="JobLink" class="form-control" placeholder="https://..." />
                    <span asp-validation-for="JobLink" class="text-danger" style="font-size:.78rem"></span>
                </div>
            </div>
        </div>

        <!-- Status & Dates -->
        <div class="form-card mb-3">
            <p class="form-section-title">Status &amp; Dates</p>
            <div class="row g-3">
                <div class="col-sm-4">
                    <label asp-for="Status" class="form-label">Status</label>
                    <select asp-for="Status" class="form-select"
                            asp-items="Html.GetEnumSelectList<InternTrackAI.Models.Enums.ApplicationStatus>()"></select>
                </div>
                <div class="col-sm-4">
                    <label asp-for="WorkMode" class="form-label">Work Mode</label>
                    <select asp-for="WorkMode" class="form-select"
                            asp-items="Html.GetEnumSelectList<InternTrackAI.Models.Enums.WorkMode>()"></select>
                </div>
                <div class="col-sm-4">
                    <label asp-for="Salary" class="form-label">Salary <span class="text-muted fw-normal">(optional)</span></label>
                    <input asp-for="Salary" class="form-control" placeholder="e.g. $30/hr" />
                </div>
                <div class="col-sm-6">
                    <label asp-for="Deadline" class="form-label">Application Deadline</label>
                    <input asp-for="Deadline" class="form-control" type="date" />
                </div>
                <div class="col-sm-6">
                    <label asp-for="DateApplied" class="form-label">Date Applied</label>
                    <input asp-for="DateApplied" class="form-control" type="date" />
                </div>
            </div>
        </div>

        <!-- Notes -->
        <div class="form-card mb-4">
            <p class="form-section-title">Notes</p>
            <label asp-for="JobDescription" class="form-label">
                Job Description / Notes <span class="text-muted fw-normal">(optional)</span>
            </label>
            <textarea asp-for="JobDescription" class="form-control"
                      placeholder="Paste the job description or add notes..."></textarea>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-dark px-4">Save Application</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>

    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
    document.getElementById('saveAnywayBtn')?.addEventListener('click', function () {
        document.getElementById('forceCreate').value = 'true';
        document.getElementById('appForm').submit();
    });
    </script>
    <script>
    (function () {
        const card       = document.getElementById('analyzerCard');
        const body       = document.getElementById('analyzerBody');
        const toggleBtn  = document.getElementById('analyzerToggleBtn');
        const textarea   = document.getElementById('analyzerTextarea');
        const analyzeBtn = document.getElementById('analyzeBtn');
        const resultEl   = document.getElementById('analyzerResult');
        const errorEl    = document.getElementById('analyzerError');

        // ── Toggle open/close ────────────────────────────────
        function setOpen(open) {
            card.classList.toggle('analyzer-open', open);
            toggleBtn.textContent = open ? 'Close' : 'Open Analyzer';
        }

        document.getElementById('analyzerToggle').addEventListener('click', function (e) {
            if (e.target === analyzeBtn) return;
            setOpen(!card.classList.contains('analyzer-open'));
        });

        // ── Analyze ──────────────────────────────────────────
        analyzeBtn.addEventListener('click', async function (e) {
            e.stopPropagation();
            const text = textarea.value.trim();
            if (!text) { textarea.focus(); return; }

            const isUrl = /^https?:\/\//i.test(text);
            setLoading(true, isUrl);
            resultEl.hidden = true;
            errorEl.hidden  = true;

            const token = document.querySelector('[name="__RequestVerificationToken"]').value;

            try {
                const resp = await fetch('/Analyzer/Analyze', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({ jobDescription: text })
                });

                const data = await resp.json();

                if (data.success) {
                    autofill('CompanyName',   data.companyName);
                    autofill('RoleTitle',     data.roleTitle);
                    autofill('Location',      data.location);
                    autofill('Salary',        data.salary);

                    // If input was a URL, auto-fill the Job Link field with it
                    if (isUrl) autofill('JobLink', text);

                    if (data.skills && data.skills.length) {
                        autofill('JobDescription',
                            'Key Skills:\n' + data.skills.map(s => '• ' + s).join('\n'));
                    }

                    showResult(data);
                    setTimeout(() => {
                        document.getElementById('appForm')
                            .scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }, 300);

                    // Auto-match against saved resume
                    runAutoMatch(text, token);
                } else {
                    showError(data.error || 'Analysis failed. Please try again.');
                }
            } catch (_) {
                showError('Request failed. Check your connection and try again.');
            } finally {
                setLoading(false);
            }
        });

        // ── Helpers ──────────────────────────────────────────
        function autofill(id, value) {
            if (!value) return;
            const el = document.getElementById(id);
            if (!el) return;
            el.value = value;
            el.classList.remove('ai-autofilled');
            void el.offsetWidth; // force reflow to restart animation
            el.classList.add('ai-autofilled');
        }

        function setLoading(on, isUrl) {
            analyzeBtn.disabled = on;
            if (on) {
                const label = isUrl ? 'Fetching page...' : 'Analyzing...';
                analyzeBtn.innerHTML =
                    '<span class="spinner-border spinner-border-sm" style="width:14px;height:14px;border-width:2px"></span> ' + label;
            } else {
                analyzeBtn.innerHTML = 'Analyze with AI';
            }
        }

        function showResult(data) {
            const filled = [data.companyName, data.roleTitle, data.location]
                .filter(Boolean).join(' · ');
            const skillsHtml = data.skills && data.skills.length
                ? `<div class="analyzer-skills">` +
                  data.skills.map(s => `<span class="analyzer-skill-tag">${s}</span>`).join('') +
                  `</div>`
                : '';

            resultEl.innerHTML =
                `<div class="analyzer-result-top">` +
                `<span class="analyzer-check"></span>` +
                `<span>Form auto-filled${filled ? ' — ' + filled : ''}</span>` +
                `</div>` + skillsHtml;
            resultEl.hidden = false;
        }

        function showError(msg) {
            errorEl.textContent = msg;
            errorEl.hidden = false;
        }

        // ── Auto-match against saved resume ──────────────
        async function runAutoMatch(jobDescription, token) {
            const wrap = document.getElementById('inlineMatchWrap');
            const card = document.getElementById('inlineMatchCard');
            wrap.hidden = true;

            try {
                const resp = await fetch('/Profile/AutoMatch', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({ jobDescription })
                });
                const d = await resp.json();

                if (!d.hasResume) return; // no active resume — silently skip

                wrap.hidden = false;

                if (!d.success) {
                    card.innerHTML = `<p style="font-size:.82rem;color:#be123c;margin:0">${d.error || 'Resume match failed.'}</p>`;
                    return;
                }

                const sc = d.score;
                const cls = sc >= 70 ? 'apply' : sc >= 40 ? 'maybe' : 'noapply';

                const matchHtml = (d.matchingSkills || []).length
                    ? (d.matchingSkills || []).map(s => `<span class="skill-tag skill-tag--match">${s}</span>`).join('')
                    : '';
                const missingHtml = (d.missingSkills || []).length
                    ? (d.missingSkills || []).map(s => `<span class="skill-tag skill-tag--missing">${s}</span>`).join('')
                    : '';

                card.innerHTML = `
                    <div class="inline-match-header">
                        <span style="font-size:.78rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.06em">Resume Match</span>
                        <span class="inline-score-pill inline-score-${cls}">${sc}% &mdash; ${d.recommendation}</span>
                    </div>
                    ${d.summary ? `<p style="font-size:.82rem;color:var(--text);margin-bottom:.6rem;line-height:1.55">${d.summary}</p>` : ''}
                    ${matchHtml || missingHtml ? `
                    <div style="display:flex;flex-wrap:wrap;gap:.75rem;">
                        ${matchHtml ? `<div><div style="font-size:.68rem;font-weight:700;color:#15803d;text-transform:uppercase;letter-spacing:.05em;margin-bottom:.3rem">Matching</div><div style="display:flex;flex-wrap:wrap;gap:.3rem">${matchHtml}</div></div>` : ''}
                        ${missingHtml ? `<div><div style="font-size:.68rem;font-weight:700;color:#be123c;text-transform:uppercase;letter-spacing:.05em;margin-bottom:.3rem">Missing</div><div style="display:flex;flex-wrap:wrap;gap:.3rem">${missingHtml}</div></div>` : ''}
                    </div>` : ''}`;
            } catch (_) {
                // network error — silently ignore
            }
        }
    })();
    </script>
}
