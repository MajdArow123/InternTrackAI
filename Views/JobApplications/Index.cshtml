@model IEnumerable<InternTrackAI.Models.JobApplication>
@using InternTrackAI.Models.Enums

@{
    ViewData["Title"] = "Applications";

    string BadgeClass(ApplicationStatus s) => s switch
    {
        ApplicationStatus.Saved     => "badge-saved",
        ApplicationStatus.Applied   => "badge-applied",
        ApplicationStatus.Interview => "badge-interview",
        ApplicationStatus.Offer     => "badge-offer",
        ApplicationStatus.Rejected  => "badge-rejected",
        _                           => ""
    };

    string StatusIcon(ApplicationStatus s) => s switch
    {
        ApplicationStatus.Saved     => "<svg class=\"status-icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z\"/></svg>",
        ApplicationStatus.Applied   => "<svg class=\"status-icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"22\" y1=\"2\" x2=\"11\" y2=\"13\"/><polygon points=\"22 2 15 22 11 13 2 9 22 2\"/></svg>",
        ApplicationStatus.Interview => "<svg class=\"status-icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\"/><line x1=\"16\" y1=\"2\" x2=\"16\" y2=\"6\"/><line x1=\"8\" y1=\"2\" x2=\"8\" y2=\"6\"/><line x1=\"3\" y1=\"10\" x2=\"21\" y2=\"10\"/></svg>",
        ApplicationStatus.Offer     => "<svg class=\"status-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\" stroke=\"none\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>",
        ApplicationStatus.Rejected  => "<svg class=\"status-icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><line x1=\"15\" y1=\"9\" x2=\"9\" y2=\"15\"/><line x1=\"9\" y1=\"9\" x2=\"15\" y2=\"15\"/></svg>",
        _                           => ""
    };

    string MatchDotClass(int score) => score switch
    {
        >= 80 => "match-dot--green",
        >= 60 => "match-dot--blue",
        >= 40 => "match-dot--amber",
        >= 20 => "match-dot--orange",
        _     => "match-dot--red"
    };

    string MatchTooltip(int score) => score switch
    {
        >= 90 => "Apply",
        >= 75 => "Apply",
        >= 60 => "Review",
        >= 45 => "Consider",
        _     => "Skip"
    };

    string Initials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}".ToUpper()
            : name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }

    bool isFiltered  = ViewBag.IsFiltered == true;
    int  totalCount  = ViewBag.TotalCount ?? 0;
    int  shownCount  = Model.Count();
}

<div class="container py-4">

    <!-- Breadcrumb -->
    <nav class="breadcrumb-nav" aria-label="breadcrumb">
        <ol class="breadcrumb-list">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li>Applications</li>
        </ol>
    </nav>

    <div class="page-header">
        <div>
            <h2>Applications</h2>
            <p class="sub">
                @if (isFiltered)
                {
                    @($"{shownCount} of {totalCount} application{(totalCount == 1 ? "" : "s")}")
                }
                else
                {
                    @($"{totalCount} application{(totalCount == 1 ? "" : "s")} total")
                }
            </p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Export" class="btn btn-outline-secondary btn-sm">Export CSV</a>
            <a asp-action="Create" class="btn btn-dark">+ Add Application</a>
        </div>
    </div>

    <!-- ── Filter Bar ── -->
    <form method="get" asp-action="Index" class="filter-bar mb-3">
        <div class="filter-group" style="flex:2;min-width:180px">
            <label class="filter-label">Search</label>
            <input type="text" name="search" class="form-control"
                   placeholder="Company or role..."
                   value="@ViewBag.Search" />
        </div>
        <div class="filter-group">
            <label class="filter-label">Status</label>
            <select name="status" class="form-select">
                <option value="">All Statuses</option>
                @foreach (var st in Enum.GetValues<ApplicationStatus>())
                {
                    if (ViewBag.Status == st.ToString())
                    {
                        <option value="@st" selected>@st</option>
                    }
                    else
                    {
                        <option value="@st">@st</option>
                    }
                }
            </select>
        </div>
        <div class="filter-group">
            <label class="filter-label">Work Mode</label>
            <select name="workMode" class="form-select">
                <option value="">All Modes</option>
                @foreach (var wm in Enum.GetValues<WorkMode>())
                {
                    if (ViewBag.WorkMode == wm.ToString())
                    {
                        <option value="@wm" selected>@wm</option>
                    }
                    else
                    {
                        <option value="@wm">@wm</option>
                    }
                }
            </select>
        </div>
        <div class="filter-group">
            <label class="filter-label">Sort By</label>
            <select name="sortBy" class="form-select">
                @{
                    string sb = ViewBag.SortBy ?? "";
                }
                @if (sb == "") { <option value="" selected>Newest First</option> }
                else           { <option value="">Newest First</option> }

                @if (sb == "company") { <option value="company" selected>Company A–Z</option> }
                else                  { <option value="company">Company A–Z</option> }

                @if (sb == "deadline") { <option value="deadline" selected>Deadline</option> }
                else                   { <option value="deadline">Deadline</option> }

                @if (sb == "dateApplied") { <option value="dateApplied" selected>Date Applied</option> }
                else                      { <option value="dateApplied">Date Applied</option> }

                @if (sb == "status") { <option value="status" selected>Status</option> }
                else                 { <option value="status">Status</option> }
            </select>
        </div>
        <div class="d-flex gap-2 align-self-end">
            <button type="submit" class="btn btn-dark btn-sm filter-apply-btn">Filter</button>
            @if (isFiltered)
            {
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm filter-apply-btn">Clear</a>
            }
        </div>
    </form>

    <!-- ── Hidden bulk action forms ── -->
    <form id="bulk-delete-form" method="post" asp-action="BulkDelete">
        @Html.AntiForgeryToken()
    </form>
    <form id="bulk-status-form" method="post" asp-action="BulkStatus">
        @Html.AntiForgeryToken()
        <input type="hidden" name="newStatus" id="bulk-status-value" />
    </form>

    @if (!Model.Any())
    {
        <div class="app-table-wrapper">
            <div class="empty-state-illustrated">
                <svg class="empty-illustration" viewBox="0 0 120 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="25" y="22" width="70" height="68" rx="6" class="empty-illu-bg" fill="#eef2ff"/>
                    <rect x="35" y="14" width="50" height="10" rx="5" class="empty-illu-top" fill="#c7d2fe"/>
                    <line x1="40" y1="48" x2="80" y2="48" class="empty-illu-line" stroke="#c7d2fe" stroke-width="3.5" stroke-linecap="round"/>
                    <line x1="40" y1="60" x2="72" y2="60" class="empty-illu-line" stroke="#c7d2fe" stroke-width="3.5" stroke-linecap="round"/>
                    <line x1="40" y1="72" x2="62" y2="72" class="empty-illu-line" stroke="#e0e7ff" stroke-width="3.5" stroke-linecap="round"/>
                </svg>
                @if (isFiltered)
                {
                    <p class="empty-state-title">No matching applications</p>
                    <p class="empty-state-desc">Try adjusting the search or status filter, or clear all filters.</p>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Clear Filters</a>
                }
                else
                {
                    <p class="empty-state-title">No applications yet</p>
                    <p class="empty-state-desc">Start tracking your internship search by logging your first application.</p>
                    <a asp-action="Create" class="btn btn-dark btn-sm">Add Your First Application</a>
                }
            </div>
        </div>
    }
    else
    {
        <div class="app-table-wrapper">
            <div class="table-responsive">
                <table class="table" id="apps-table">
                    <thead>
                        <tr>
                            <th class="ps-3" style="width:2.5rem">
                                <input type="checkbox" id="select-all-check" class="form-check-input"
                                       style="margin:0;cursor:pointer" />
                            </th>
                            <th class="ps-2">Company</th>
                            <th>Role</th>
                            <th class="d-none d-md-table-cell">Location</th>
                            <th class="d-none d-md-table-cell">Mode</th>
                            <th>Status</th>
                            <th class="text-center d-none d-sm-table-cell" style="width:3.5rem">Match</th>
                            <th class="d-none d-sm-table-cell">Deadline</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr data-app-id="@item.Id"
                                data-company="@item.CompanyName"
                                data-role="@item.RoleTitle"
                                data-location="@(item.Location ?? "")"
                                data-salary="@(item.Salary ?? "")"
                                data-match-score="@(item.MatchScore?.ToString() ?? "")"
                                data-match-rec="@(item.MatchRecommendation ?? "")"
                                data-status="@item.Status"
                                data-deadline="@(item.Deadline.HasValue ? item.Deadline.Value.ToString("MMM d, yyyy") : "")"
                                data-mode="@item.WorkMode"
                                data-job-description="@(System.Net.WebUtility.HtmlEncode(item.JobDescription ?? ""))"
                                class="app-row"
                                role="button"
                                tabindex="0">
                                <td class="ps-3" style="width:2.5rem">
                                    <input type="checkbox" class="form-check-input row-check"
                                           value="@item.Id" style="margin:0;cursor:pointer" />
                                </td>
                                <td class="ps-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="company-avatar">@Initials(item.CompanyName)</span>
                                        <span class="company-name">@item.CompanyName</span>
                                    </div>
                                </td>
                                <td class="role-name">@item.RoleTitle</td>
                                <td class="text-muted d-none d-md-table-cell">@(item.Location ?? "—")</td>
                                <td class="text-muted d-none d-md-table-cell">@item.WorkMode</td>
                                <td>
                                    <span class="status-badge @BadgeClass(item.Status)">
                                        @Html.Raw(StatusIcon(item.Status)) @item.Status
                                    </span>
                                </td>
                                <td class="text-center d-none d-sm-table-cell">
                                    @if (item.MatchScore.HasValue)
                                    {
                                        var action = MatchTooltip(item.MatchScore.Value);
                                        var tooltip = $"{item.MatchScore}% Match · {action}";
                                        <span class="match-dot @MatchDotClass(item.MatchScore.Value)"
                                              data-bs-toggle="tooltip"
                                              data-bs-placement="top"
                                              data-bs-title="@tooltip"
                                              aria-label="@tooltip"></span>
                                    }
                                </td>
                                <td class="text-muted d-none d-sm-table-cell">
                                    @(item.Deadline.HasValue ? item.Deadline.Value.ToString("MMM d, yyyy") : "—")
                                </td>
                                <td class="text-end pe-3">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <a asp-controller="CoverLetter" asp-action="Generate"
                                           asp-route-appId="@item.Id"
                                           class="btn btn-sm btn-outline-primary row-action-btn">Cover Letter</a>
                                        <a asp-controller="InterviewPrep" asp-action="Prep"
                                           asp-route-appId="@item.Id"
                                           class="btn btn-sm btn-outline-primary row-action-btn">Interview Prep</a>
                                        <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-secondary row-action-btn">Edit</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<!-- ── Bulk Action Bar ── -->
<div id="bulk-bar" class="bulk-bar">
    <div class="bulk-bar-inner container">
        <span id="bulk-count" class="bulk-count">0 selected</span>
        <div class="bulk-actions">
            <button type="button" class="btn btn-sm btn-outline-light" id="compare-btn" style="display:none">
                Compare
            </button>
            <div class="d-flex align-items-center gap-2">
                <select id="bulk-status-select" class="form-select form-select-sm bulk-status-select">
                    <option value="">Change status to...</option>
                    @foreach (var st in Enum.GetValues<ApplicationStatus>())
                    {
                        <option value="@st">@st</option>
                    }
                </select>
                <button type="button" class="btn btn-sm btn-outline-light" id="bulk-status-btn">Apply</button>
            </div>
            <button type="button" class="btn btn-sm btn-danger" id="bulk-delete-btn">Delete Selected</button>
            <button type="button" class="btn btn-sm btn-link bulk-deselect-link" id="bulk-deselect-btn">Deselect All</button>
        </div>
    </div>
</div>

<!-- ── Job Comparison Modal ── -->
<div id="compare-overlay" class="compare-modal-overlay" aria-hidden="true" role="dialog" aria-label="Compare applications">
    <div class="compare-modal">
        <div class="compare-modal-header">
            <span class="compare-modal-title">Side-by-Side Comparison</span>
            <button class="compare-modal-close" id="compare-close" aria-label="Close">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div id="compare-content"></div>
    </div>
</div>

<!-- ── Application Detail Drawer ── -->
<div id="app-drawer-backdrop" class="app-drawer-backdrop" aria-hidden="true"></div>
<div id="app-drawer" class="app-drawer" aria-hidden="true" role="dialog" aria-label="Application details">
    <div class="app-drawer-content">
        <!-- Header -->
        <div class="app-drawer-header">
            <div class="app-drawer-header-main">
                <div>
                    <h2 id="drawer-role" class="app-drawer-title">Role Title</h2>
                    <p id="drawer-company" class="app-drawer-company">Company Name</p>
                </div>
                <span id="drawer-status-badge" class="status-badge"></span>
            </div>
            <button class="app-drawer-close" id="drawer-close" aria-label="Close">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>

        <!-- Scrollable Content -->
        <div class="app-drawer-body">
            <!-- Job Description Section -->
            <section class="drawer-section">
                <h3 class="drawer-section-title">Job Description</h3>
                <p id="drawer-description" class="drawer-text">Loading...</p>
            </section>

            <!-- AI Analysis Section -->
            <section class="drawer-section">
                <h3 class="drawer-section-title">AI Analysis</h3>

                <!-- Match Score -->
                <div class="match-score-container">
                    <div id="drawer-match-score" class="match-score-display">95%</div>
                    <div class="match-score-label" id="drawer-match-label">Excellent match</div>
                </div>

                <!-- Strong Points -->
                <div class="analysis-subsection">
                    <h4 class="analysis-subtitle">
                        <svg class="analysis-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                        Strong Points
                    </h4>
                    <ul id="drawer-strong-points" class="analysis-list">
                        <li>Strong Python background</li>
                        <li>Experience with cloud platforms</li>
                        <li>Excellent communication skills</li>
                    </ul>
                </div>

                <!-- Weak Points -->
                <div class="analysis-subsection">
                    <h4 class="analysis-subtitle">
                        <svg class="analysis-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <line x1="18" y1="6" x2="6" y2="18"></line>
                            <line x1="6" y1="6" x2="18" y2="18"></line>
                        </svg>
                        Areas to Improve
                    </h4>
                    <ul id="drawer-weak-points" class="analysis-list">
                        <li>Limited Kubernetes experience</li>
                        <li>No Docker background yet</li>
                    </ul>
                </div>

                <!-- Suggestions -->
                <div class="analysis-subsection">
                    <h4 class="analysis-subtitle">
                        <svg class="analysis-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <circle cx="12" cy="12" r="10"></circle>
                            <path d="M12 16v-4M12 8h.01"></path>
                        </svg>
                        Suggestions
                    </h4>
                    <ul id="drawer-suggestions" class="analysis-list">
                        <li>Consider taking a Kubernetes course before applying</li>
                        <li>Build a Docker project to showcase practical experience</li>
                    </ul>
                </div>
            </section>

            <!-- Additional Info -->
            <section class="drawer-section">
                <div class="drawer-info-grid">
                    <div class="drawer-info-item">
                        <span class="drawer-info-label">Location</span>
                        <span id="drawer-location" class="drawer-info-value">Toronto, ON</span>
                    </div>
                    <div class="drawer-info-item">
                        <span class="drawer-info-label">Work Mode</span>
                        <span id="drawer-mode" class="drawer-info-value">Remote</span>
                    </div>
                    <div class="drawer-info-item">
                        <span class="drawer-info-label">Salary</span>
                        <span id="drawer-salary" class="drawer-info-value">$22-26/hour</span>
                    </div>
                    <div class="drawer-info-item">
                        <span class="drawer-info-label">Deadline</span>
                        <span id="drawer-deadline" class="drawer-info-value">Jul 30, 2026</span>
                    </div>
                </div>
            </section>
        </div>

        <!-- Action Buttons -->
        <div class="app-drawer-footer">
            <button id="drawer-edit-btn" class="btn btn-outline-secondary btn-sm" data-app-id="">Edit</button>
            <button id="drawer-cover-letter-btn" class="btn btn-outline-primary btn-sm" data-app-id="">Cover Letter</button>
            <button id="drawer-interview-btn" class="btn btn-outline-primary btn-sm" data-app-id="">Interview Prep</button>
            <button id="drawer-close-btn" class="btn btn-secondary btn-sm">Close</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.querySelectorAll('.match-dot[data-bs-toggle="tooltip"]').forEach(function (el) {
    new bootstrap.Tooltip(el);
});
</script>
<script>
(function () {
    const checkboxes   = Array.from(document.querySelectorAll('.row-check'));
    const selectAll    = document.getElementById('select-all-check');
    const bulkBar      = document.getElementById('bulk-bar');
    const bulkCount    = document.getElementById('bulk-count');
    const deleteBtn    = document.getElementById('bulk-delete-btn');
    const statusBtn    = document.getElementById('bulk-status-btn');
    const deselectBtn  = document.getElementById('bulk-deselect-btn');
    const statusSelect = document.getElementById('bulk-status-select');
    const compareBtn   = document.getElementById('compare-btn');
    const compareOverlay = document.getElementById('compare-overlay');

    function selectedRows() {
        return checkboxes.filter(cb => cb.checked).map(cb => cb.closest('tr'));
    }
    function selectedIds() {
        return checkboxes.filter(cb => cb.checked).map(cb => cb.value);
    }

    function updateBar() {
        const ids = selectedIds();
        const n   = ids.length;
        bulkCount.textContent = n + ' selected';
        bulkBar.classList.toggle('show', n > 0);
        if (compareBtn) compareBtn.style.display = (n >= 2 && n <= 3) ? 'inline-flex' : 'none';
        if (selectAll) {
            selectAll.indeterminate = n > 0 && n < checkboxes.length;
            selectAll.checked       = n === checkboxes.length && checkboxes.length > 0;
        }
    }

    checkboxes.forEach(cb => cb.addEventListener('change', updateBar));

    selectAll?.addEventListener('change', function () {
        checkboxes.forEach(cb => { cb.checked = this.checked; });
        updateBar();
    });

    deselectBtn?.addEventListener('click', function () {
        checkboxes.forEach(cb => { cb.checked = false; });
        if (selectAll) selectAll.checked = false;
        updateBar();
    });

    deleteBtn?.addEventListener('click', function () {
        const ids = selectedIds();
        if (!ids.length) return;
        if (!confirm('Delete ' + ids.length + ' application' + (ids.length > 1 ? 's' : '') + '? This cannot be undone.')) return;
        submitBulk('bulk-delete-form', ids, null);
    });

    statusBtn?.addEventListener('click', function () {
        const newStatus = statusSelect.value;
        const ids       = selectedIds();
        if (!newStatus) { statusSelect.focus(); return; }
        if (!ids.length) return;
        submitBulk('bulk-status-form', ids, newStatus);
    });

    function submitBulk(formId, ids, status) {
        const form = document.getElementById(formId);
        form.querySelectorAll('input[name="ids"]').forEach(el => el.remove());
        if (status !== null) {
            const sv = document.getElementById('bulk-status-value');
            if (sv) sv.value = status;
        }
        ids.forEach(id => {
            const inp = document.createElement('input');
            inp.type  = 'hidden';
            inp.name  = 'ids';
            inp.value = id;
            form.appendChild(inp);
        });
        form.submit();
    }

    // ── Comparison ───────────────────────────────────────
    function getAppData(row) {
        return {
            company:    row.dataset.company    || '—',
            role:       row.dataset.role       || '—',
            location:   row.dataset.location   || '—',
            salary:     row.dataset.salary     || '—',
            matchScore: row.dataset.matchScore || null,
            matchRec:   row.dataset.matchRec   || '—',
            status:     row.dataset.status     || '—',
            deadline:   row.dataset.deadline   || '—',
            mode:       row.dataset.mode       || '—'
        };
    }

    function escHtml(s) {
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function renderComparison(apps) {
        const cols = apps.length;
        const fields = [
            { label: 'Company',      key: 'company' },
            { label: 'Role',         key: 'role' },
            { label: 'Location',     key: 'location' },
            { label: 'Salary',       key: 'salary' },
            { label: 'Work Mode',    key: 'mode' },
            { label: 'Status',       key: 'status' },
            { label: 'Match Score',  key: 'matchScore', render: v => v ? v + '%' : '—' },
            { label: 'Rec.',         key: 'matchRec' },
            { label: 'Deadline',     key: 'deadline' }
        ];

        let html = '<div class="compare-grid" data-cols="' + cols + '" style="grid-template-columns:repeat(' + cols + ',1fr)">';
        apps.forEach(function(app) {
            html += '<div class="compare-col">';
            html += '<div class="compare-col-header">';
            html += '<div class="compare-company">' + escHtml(app.company) + '</div>';
            html += '<div class="compare-role">' + escHtml(app.role) + '</div>';
            html += '</div>';
            fields.slice(2).forEach(function(f) {
                var val = app[f.key];
                var display = f.render ? f.render(val) : (val || '—');
                html += '<div class="compare-field">';
                html += '<span class="compare-field-label">' + escHtml(f.label) + '</span>';
                html += '<span class="compare-field-value">' + escHtml(display) + '</span>';
                html += '</div>';
            });
            html += '</div>';
        });
        html += '</div>';

        document.getElementById('compare-content').innerHTML = html;
    }

    function openCompare() {
        var rows = selectedRows();
        if (rows.length < 2 || rows.length > 3) return;
        renderComparison(rows.map(getAppData));
        compareOverlay.classList.add('active');
        compareOverlay.setAttribute('aria-hidden', 'false');
    }
    function closeCompare() {
        compareOverlay.classList.remove('active');
        compareOverlay.setAttribute('aria-hidden', 'true');
    }

    compareBtn?.addEventListener('click', openCompare);
    document.getElementById('compare-close')?.addEventListener('click', closeCompare);
    compareOverlay?.addEventListener('click', function(e) { if (e.target === compareOverlay) closeCompare(); });
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeCompare(); });
})();
</script>

<!-- ── Application Detail Drawer Script ── -->
<script>
(function () {
    const drawer = document.getElementById('app-drawer');
    const backdrop = document.getElementById('app-drawer-backdrop');
    const closeBtn = document.getElementById('drawer-close');
    const closeFooterBtn = document.getElementById('drawer-close-btn');
    const appRows = document.querySelectorAll('.app-row');

    const statusNames = ['Saved', 'Applied', 'Interview', 'Rejected', 'Offer'];
    const statusBadgeClasses = {
        0: 'badge-saved',
        1: 'badge-applied',
        2: 'badge-interview',
        3: 'badge-rejected',
        4: 'badge-offer'
    };

    const statusIcons = {
        0: '<svg class="status-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>',
        1: '<svg class="status-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>',
        2: '<svg class="status-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>',
        4: '<svg class="status-icon" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>',
        3: '<svg class="status-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>'
    };

    function getMatchLabel(score) {
        if (score >= 90) return 'Excellent match';
        if (score >= 75) return 'Good match';
        if (score >= 60) return 'Fair match';
        if (score >= 45) return 'Weak match';
        return 'Poor match';
    }

    function getMatchScoreClass(score) {
        if (score >= 90) return 'score-90';
        if (score >= 75) return 'score-75';
        if (score >= 60) return 'score-60';
        if (score >= 45) return 'score-45';
        return 'score-low';
    }

    function generateAnalysisPoints(score) {
        const highScorePoints = {
            strong: ['Perfect technical fit', 'Strong relevant experience', 'Excellent soft skills match'],
            weak: [],
            suggestions: ['Highlight your best projects', 'Emphasize team experience']
        };

        const midScorePoints = {
            strong: ['Good technical foundation', 'Relevant coursework'],
            weak: ['Limited production experience', 'Some skill gaps'],
            suggestions: ['Highlight transferable skills', 'Show willingness to learn']
        };

        const lowScorePoints = {
            strong: ['Basic technical competency', 'Enthusiasm for learning'],
            weak: ['Significant skill gaps', 'Limited relevant experience'],
            suggestions: ['Consider upskilling first', 'Look for more beginner-friendly roles']
        };

        if (score >= 75) return highScorePoints;
        if (score >= 50) return midScorePoints;
        return lowScorePoints;
    }

    function openDrawer(appRow) {
        const data = {
            id: appRow.dataset.appId,
            company: appRow.dataset.company,
            role: appRow.dataset.role,
            location: appRow.dataset.location,
            salary: appRow.dataset.salary,
            mode: appRow.dataset.mode,
            status: parseInt(appRow.dataset.status),
            deadline: appRow.dataset.deadline,
            matchScore: appRow.dataset.matchScore ? parseInt(appRow.dataset.matchScore) : null,
            matchRec: appRow.dataset.matchRec,
            description: appRow.dataset.jobDescription
        };

        // Header
        document.getElementById('drawer-role').textContent = data.role;
        document.getElementById('drawer-company').textContent = data.company;

        // Status badge
        const statusBadge = document.getElementById('drawer-status-badge');
        const statusNum = data.status;
        statusBadge.className = 'status-badge ' + (statusBadgeClasses[statusNum] || '');
        statusBadge.innerHTML = statusIcons[statusNum] + ' ' + statusNames[statusNum];

        // Description
        document.getElementById('drawer-description').textContent = data.description || 'No description available';

        // Match score
        if (data.matchScore) {
            const scoreEl = document.getElementById('drawer-match-score');
            scoreEl.textContent = data.matchScore + '%';
            scoreEl.className = 'match-score-display ' + getMatchScoreClass(data.matchScore);
            document.getElementById('drawer-match-label').textContent = getMatchLabel(data.matchScore);

            // Generate analysis based on score
            const analysis = generateAnalysisPoints(data.matchScore);
            document.getElementById('drawer-strong-points').innerHTML = analysis.strong.map(p => '<li>' + p + '</li>').join('');
            document.getElementById('drawer-weak-points').innerHTML = analysis.weak.map(p => '<li>' + p + '</li>').join('');
            document.getElementById('drawer-suggestions').innerHTML = analysis.suggestions.map(p => '<li>' + p + '</li>').join('');
        }

        // Additional info
        document.getElementById('drawer-location').textContent = data.location || '—';
        document.getElementById('drawer-mode').textContent = data.mode || '—';
        document.getElementById('drawer-salary').textContent = data.salary || '—';
        document.getElementById('drawer-deadline').textContent = data.deadline || '—';

        // Action buttons
        const editBtn = document.getElementById('drawer-edit-btn');
        const clBtn = document.getElementById('drawer-cover-letter-btn');
        const intBtn = document.getElementById('drawer-interview-btn');

        editBtn.dataset.appId = data.id;
        editBtn.onclick = function() { window.location.href = '/JobApplications/Edit/' + data.id; };

        clBtn.dataset.appId = data.id;
        clBtn.onclick = function() { window.location.href = '/CoverLetter/Generate?appId=' + data.id; };

        intBtn.dataset.appId = data.id;
        intBtn.onclick = function() { window.location.href = '/InterviewPrep/Prep?appId=' + data.id; };

        // Show drawer
        drawer.classList.add('active');
        backdrop.classList.add('active');
        drawer.setAttribute('aria-hidden', 'false');
        backdrop.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
        drawer.classList.remove('active');
        backdrop.classList.remove('active');
        drawer.setAttribute('aria-hidden', 'true');
        backdrop.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
    }

    // Event listeners
    appRows.forEach(row => {
        row.addEventListener('click', function(e) {
            // Don't open drawer if clicking on checkboxes or buttons
            if (e.target.closest('.row-check, .row-action-btn')) return;
            openDrawer(this);
        });
        row.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                openDrawer(this);
            }
        });
    });

    closeBtn.addEventListener('click', closeDrawer);
    closeFooterBtn.addEventListener('click', closeDrawer);
    backdrop.addEventListener('click', closeDrawer);
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && drawer.classList.contains('active')) {
            closeDrawer();
        }
    });
})();
</script>
}
