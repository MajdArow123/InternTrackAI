@model IEnumerable<InternTrackAI.Models.JobApplication>
@using InternTrackAI.Models.Enums

@{
    ViewData["Title"] = "Applications";

    string BadgeClass(ApplicationStatus s) => s switch
    {
        ApplicationStatus.Saved     => "badge-saved",
        ApplicationStatus.Applied   => "badge-applied",
        ApplicationStatus.Interview => "badge-interview",
        ApplicationStatus.Offer     => "badge-offer",
        ApplicationStatus.Rejected  => "badge-rejected",
        _                           => ""
    };

    string Initials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}".ToUpper()
            : name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }

    bool isFiltered  = ViewBag.IsFiltered == true;
    int  totalCount  = ViewBag.TotalCount ?? 0;
    int  shownCount  = Model.Count();
}

<div class="container py-4">

    <div class="page-header">
        <div>
            <h2>Applications</h2>
            <p class="sub">
                @if (isFiltered)
                {
                    @($"{shownCount} of {totalCount} application{(totalCount == 1 ? "" : "s")}")
                }
                else
                {
                    @($"{totalCount} application{(totalCount == 1 ? "" : "s")} total")
                }
            </p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Export" class="btn btn-outline-secondary btn-sm">Export CSV</a>
            <a asp-action="Create" class="btn btn-dark">+ Add Application</a>
        </div>
    </div>

    <!-- ── Filter Bar ── -->
    <form method="get" asp-action="Index" class="filter-bar mb-3">
        <div class="filter-group" style="flex:2;min-width:180px">
            <label class="filter-label">Search</label>
            <input type="text" name="search" class="form-control"
                   placeholder="Company or role..."
                   value="@ViewBag.Search" />
        </div>
        <div class="filter-group">
            <label class="filter-label">Status</label>
            <select name="status" class="form-select">
                <option value="">All Statuses</option>
                @foreach (var st in Enum.GetValues<ApplicationStatus>())
                {
                    if (ViewBag.Status == st.ToString())
                    {
                        <option value="@st" selected>@st</option>
                    }
                    else
                    {
                        <option value="@st">@st</option>
                    }
                }
            </select>
        </div>
        <div class="filter-group">
            <label class="filter-label">Work Mode</label>
            <select name="workMode" class="form-select">
                <option value="">All Modes</option>
                @foreach (var wm in Enum.GetValues<WorkMode>())
                {
                    if (ViewBag.WorkMode == wm.ToString())
                    {
                        <option value="@wm" selected>@wm</option>
                    }
                    else
                    {
                        <option value="@wm">@wm</option>
                    }
                }
            </select>
        </div>
        <div class="filter-group">
            <label class="filter-label">Sort By</label>
            <select name="sortBy" class="form-select">
                @{
                    string sb = ViewBag.SortBy ?? "";
                }
                @if (sb == "") { <option value="" selected>Newest First</option> }
                else           { <option value="">Newest First</option> }

                @if (sb == "company") { <option value="company" selected>Company A–Z</option> }
                else                  { <option value="company">Company A–Z</option> }

                @if (sb == "deadline") { <option value="deadline" selected>Deadline</option> }
                else                   { <option value="deadline">Deadline</option> }

                @if (sb == "dateApplied") { <option value="dateApplied" selected>Date Applied</option> }
                else                      { <option value="dateApplied">Date Applied</option> }

                @if (sb == "status") { <option value="status" selected>Status</option> }
                else                 { <option value="status">Status</option> }
            </select>
        </div>
        <div class="d-flex gap-2 align-self-end">
            <button type="submit" class="btn btn-dark btn-sm filter-apply-btn">Filter</button>
            @if (isFiltered)
            {
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm filter-apply-btn">Clear</a>
            }
        </div>
    </form>

    <!-- ── Hidden bulk action forms ── -->
    <form id="bulk-delete-form" method="post" asp-action="BulkDelete">
        @Html.AntiForgeryToken()
    </form>
    <form id="bulk-status-form" method="post" asp-action="BulkStatus">
        @Html.AntiForgeryToken()
        <input type="hidden" name="newStatus" id="bulk-status-value" />
    </form>

    @if (!Model.Any())
    {
        <div class="app-table-wrapper">
            <div class="empty-state">
                @if (isFiltered)
                {
                    <p class="fw-semibold mb-1" style="color:var(--text)">No applications match your filters.</p>
                    <p class="mb-3">Try adjusting the search or status filter, or clear all filters.</p>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Clear Filters</a>
                }
                else
                {
                    <p class="fw-semibold mb-1" style="color:var(--text)">No applications yet.</p>
                    <p class="mb-3">Start tracking your internship search by adding your first application.</p>
                    <a asp-action="Create" class="btn btn-dark btn-sm">Add Your First Application</a>
                }
            </div>
        </div>
    }
    else
    {
        <div class="app-table-wrapper">
            <div class="table-responsive">
                <table class="table" id="apps-table">
                    <thead>
                        <tr>
                            <th class="ps-3" style="width:2.5rem">
                                <input type="checkbox" id="select-all-check" class="form-check-input"
                                       style="margin:0;cursor:pointer" />
                            </th>
                            <th class="ps-2">Company</th>
                            <th>Role</th>
                            <th class="d-none d-md-table-cell">Location</th>
                            <th class="d-none d-md-table-cell">Mode</th>
                            <th>Status</th>
                            <th class="d-none d-sm-table-cell">Deadline</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3" style="width:2.5rem">
                                    <input type="checkbox" class="form-check-input row-check"
                                           value="@item.Id" style="margin:0;cursor:pointer" />
                                </td>
                                <td class="ps-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="company-avatar">@Initials(item.CompanyName)</span>
                                        <span class="company-name">@item.CompanyName</span>
                                    </div>
                                </td>
                                <td class="role-name">@item.RoleTitle</td>
                                <td class="text-muted d-none d-md-table-cell">@(item.Location ?? "—")</td>
                                <td class="text-muted d-none d-md-table-cell">@item.WorkMode</td>
                                <td>
                                    <span class="status-badge @BadgeClass(item.Status)">@item.Status</span>
                                </td>
                                <td class="text-muted d-none d-sm-table-cell">
                                    @(item.Deadline.HasValue ? item.Deadline.Value.ToString("MMM d, yyyy") : "—")
                                </td>
                                <td class="text-end pe-3">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <a asp-controller="CoverLetter" asp-action="Generate"
                                           asp-route-appId="@item.Id"
                                           class="btn btn-sm btn-outline-primary row-action-btn">Cover Letter</a>
                                        <a asp-controller="InterviewPrep" asp-action="Prep"
                                           asp-route-appId="@item.Id"
                                           class="btn btn-sm btn-outline-primary row-action-btn">Interview Prep</a>
                                        <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-secondary row-action-btn">Edit</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<!-- ── Bulk Action Bar ── -->
<div id="bulk-bar" class="bulk-bar">
    <div class="bulk-bar-inner container">
        <span id="bulk-count" class="bulk-count">0 selected</span>
        <div class="bulk-actions">
            <div class="d-flex align-items-center gap-2">
                <select id="bulk-status-select" class="form-select form-select-sm bulk-status-select">
                    <option value="">Change status to...</option>
                    @foreach (var st in Enum.GetValues<ApplicationStatus>())
                    {
                        <option value="@st">@st</option>
                    }
                </select>
                <button type="button" class="btn btn-sm btn-outline-light" id="bulk-status-btn">Apply</button>
            </div>
            <button type="button" class="btn btn-sm btn-danger" id="bulk-delete-btn">Delete Selected</button>
            <button type="button" class="btn btn-sm btn-link bulk-deselect-link" id="bulk-deselect-btn">Deselect All</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const checkboxes   = Array.from(document.querySelectorAll('.row-check'));
    const selectAll    = document.getElementById('select-all-check');
    const bulkBar      = document.getElementById('bulk-bar');
    const bulkCount    = document.getElementById('bulk-count');
    const deleteBtn    = document.getElementById('bulk-delete-btn');
    const statusBtn    = document.getElementById('bulk-status-btn');
    const deselectBtn  = document.getElementById('bulk-deselect-btn');
    const statusSelect = document.getElementById('bulk-status-select');

    function selectedIds() {
        return checkboxes.filter(cb => cb.checked).map(cb => cb.value);
    }

    function updateBar() {
        const ids = selectedIds();
        if (ids.length > 0) {
            bulkBar.classList.add('show');
            bulkCount.textContent = ids.length + ' selected';
        } else {
            bulkBar.classList.remove('show');
        }
        if (selectAll) {
            selectAll.indeterminate = ids.length > 0 && ids.length < checkboxes.length;
            selectAll.checked = ids.length === checkboxes.length && checkboxes.length > 0;
        }
    }

    checkboxes.forEach(cb => cb.addEventListener('change', updateBar));

    selectAll?.addEventListener('change', function () {
        checkboxes.forEach(cb => { cb.checked = this.checked; });
        updateBar();
    });

    deselectBtn?.addEventListener('click', function () {
        checkboxes.forEach(cb => { cb.checked = false; });
        if (selectAll) selectAll.checked = false;
        updateBar();
    });

    deleteBtn?.addEventListener('click', function () {
        const ids = selectedIds();
        if (!ids.length) return;
        if (!confirm('Delete ' + ids.length + ' application' + (ids.length > 1 ? 's' : '') + '? This cannot be undone.')) return;
        submitBulk('bulk-delete-form', ids, null);
    });

    statusBtn?.addEventListener('click', function () {
        const newStatus = statusSelect.value;
        const ids       = selectedIds();
        if (!newStatus) { statusSelect.focus(); return; }
        if (!ids.length) return;
        submitBulk('bulk-status-form', ids, newStatus);
    });

    function submitBulk(formId, ids, status) {
        const form = document.getElementById(formId);
        form.querySelectorAll('input[name="ids"]').forEach(el => el.remove());
        if (status !== null) {
            const sv = document.getElementById('bulk-status-value');
            if (sv) sv.value = status;
        }
        ids.forEach(id => {
            const inp = document.createElement('input');
            inp.type  = 'hidden';
            inp.name  = 'ids';
            inp.value = id;
            form.appendChild(inp);
        });
        form.submit();
    }
})();
</script>
}
