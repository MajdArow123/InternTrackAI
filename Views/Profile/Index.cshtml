@model InternTrackAI.Models.ViewModels.ProfileViewModel
@using System.Globalization

@{
    ViewData["Title"] = "Profile";

    var userId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

    var initials = string.IsNullOrWhiteSpace(Model.Profile.FullName)
        ? (Model.Email?.Substring(0, 1).ToUpperInvariant() ?? "?")
        : string.Concat(Model.Profile.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
              .Take(2).Select(w => char.ToUpperInvariant(w[0])));

    var photoPath = Model.Profile.PhotoFileName != null
        ? $"/uploads/photos/{Model.Profile.PhotoFileName}?v={Model.Profile.PhotoVersion}"
        : null;

    // Score ring vars
    const double Circ = 339.29;
    int scoreDashOff = (int)Circ;
    string scoreColor = "maybe";
    if (Model.ScoreResult?.Success == true)
    {
        scoreDashOff = (int)(Circ * (1.0 - Model.ScoreResult.Score / 100.0));
        scoreColor   = Model.ScoreResult.Score >= 70 ? "apply" : Model.ScoreResult.Score >= 40 ? "maybe" : "noapply";
    }
    string CircStr = Circ.ToString("F2", CultureInfo.InvariantCulture);
}

<div class="container py-4" style="max-width:900px;">

    <!-- Breadcrumb -->
    <nav class="breadcrumb-nav" aria-label="breadcrumb">
        <ol class="breadcrumb-list">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li>Profile</li>
        </ol>
    </nav>

    <div class="page-header">
        <div>
            <h2>Profile</h2>
            <p class="sub">Manage your career information, documents, and AI tools</p>
        </div>
        <a asp-area="Identity" asp-page="/Account/Manage/Index"
           class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center gap-1">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
            </svg>
            Account Settings
        </a>
    </div>

    <!-- ── Resumes (moved to top: upload + AI auto-fill is the natural starting point) ── -->
    <div class="form-card mb-3 resume-hero-card @(Model.Resumes.Any() ? "has-resume" : "")" id="resumeHeroCard">
        <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
            <p class="form-section-title mb-0">Resume</p>
            <span class="text-muted" style="font-size:.75rem">@Model.Resumes.Count version(s)</span>
        </div>

        @if (Model.Resumes.Any())
        {
            <div class="doc-list mb-3">
                @foreach (var r in Model.Resumes)
                {
                    <div class="doc-row @(r.IsActive ? "doc-active" : "")">
                        <span class="doc-version-badge">v@(r.VersionNumber)</span>
                        <div class="doc-info">
                            <div class="doc-filename">@r.OriginalFileName</div>
                            <div class="doc-meta">
                                @r.UploadedAt.ToLocalTime().ToString("MMM d, yyyy") &middot;
                                @((r.FileSize / 1024.0).ToString("F0")) KB
                            </div>
                        </div>
                        @if (r.IsActive)
                        {
                            <span class="active-label">Active</span>
                        }
                        else
                        {
                            <form asp-action="SetActiveResume" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@r.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-primary" style="font-size:.72rem;padding:.2rem .6rem;">Set Active</button>
                            </form>
                        }
                        <a asp-action="DownloadResume" asp-route-id="@r.Id"
                           class="btn btn-sm btn-outline-secondary" style="font-size:.72rem;padding:.2rem .6rem;">Download</a>
                        <form asp-action="DeleteResume" method="post" class="d-inline"
                              onsubmit="return confirm('Delete Resume v@(r.VersionNumber)? This cannot be undone.')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@r.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger" style="font-size:.72rem;padding:.2rem .6rem;">Delete</button>
                        </form>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted mb-3" style="font-size:.875rem">No resume uploaded yet. Upload one below, then let AI fill in your name, skills, and target roles.</p>
        }

        <form asp-action="UploadResume" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <input type="file" name="resume" accept=".pdf"
                       class="form-control" style="width:auto;font-size:.875rem;" />
                <button type="submit" class="btn btn-dark">Upload New Resume</button>
                <span class="text-muted" style="font-size:.75rem">PDF only &middot; Max 5 MB</span>
            </div>
        </form>

        @if (Model.Resumes.Any(r => r.IsActive))
        {
            <div class="mt-3 pt-3" style="border-top:1px solid var(--border)">
                <button type="button" class="analyze-btn" id="analyzeBtn">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2l1.8 5.5L19 9l-5.2 1.5L12 16l-1.8-5.5L5 9l5.2-1.5z"/>
                    </svg>
                    <span id="analyzeBtnLabel">Analyze with AI</span>
                </button>
                <span class="ms-2 text-muted" style="font-size:.78rem">Auto-fills your name, skills, and target roles from your active resume</span>
                <div id="analyzeError" class="match-error-banner mt-2" style="display:none"></div>
            </div>
        }
    </div>

    <!-- Quick Stats -->
    @if (Model.TotalApplications > 0)
    {
        <div class="quick-stats-row">
            <div class="quick-stat-card">
                <div class="quick-stat-label">This Month</div>
                <div class="quick-stat-value">@Model.ApplicationsThisMonth</div>
                <div class="quick-stat-sub">application@(Model.ApplicationsThisMonth == 1 ? "" : "s") applied</div>
            </div>

            <div class="quick-stat-card">
                <div class="quick-stat-label">Upcoming Deadlines</div>
                @if (Model.UpcomingDeadlines7Days.Any())
                {
                    <div class="quick-stat-value">@Model.UpcomingDeadlines7Days.Count</div>
                    <div class="quick-deadline-list">
                        @foreach (var app in Model.UpcomingDeadlines7Days.Take(3))
                        {
                            var daysLeft = (app.Deadline!.Value.Date - DateTime.UtcNow.Date).Days;
                            var urgent   = daysLeft <= 2;
                            <div class="quick-deadline-item">
                                <span class="@(urgent ? "quick-deadline-urgent" : "")">@app.CompanyName</span>
                                <span class="quick-deadline-date">@(daysLeft == 0 ? "Today" : daysLeft == 1 ? "Tomorrow" : $"{daysLeft}d")</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="quick-stat-value">0</div>
                    <div class="quick-stat-sub">in the next 7 days</div>
                }
            </div>

            <div class="quick-stat-card">
                <div class="quick-stat-label">Recent Matches</div>
                @if (Model.RecentMatchedApps.Any())
                {
                    <div class="quick-stat-value">@Model.RecentMatchedApps.Count</div>
                    <div class="quick-match-list">
                        @foreach (var app in Model.RecentMatchedApps)
                        {
                            var sc       = app.MatchScore!.Value;
                            var tierCls  = sc >= 80 ? "match-tier-5" : sc >= 60 ? "match-tier-4" : sc >= 40 ? "match-tier-3" : sc >= 20 ? "match-tier-2" : "match-tier-1";
                            <div class="quick-match-item">
                                <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@app.CompanyName</span>
                                <span class="match-rec-badge @tierCls" style="font-size:.68rem;padding:.12em .55em">@sc%</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="quick-stat-value">—</div>
                    <div class="quick-stat-sub">no resume analyses yet</div>
                }
            </div>
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-dismissible fade show py-2 mb-3 profile-success-alert" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="match-error-banner mb-3">@TempData["Error"]</div>
    }
    @if (TempData["ScoreError"] != null)
    {
        <div class="match-error-banner mb-3">@TempData["ScoreError"]</div>
    }

    <!-- ── Personal Info ── -->
    <div class="form-card mb-3">
        <p class="form-section-title">Personal Info</p>

        <div class="profile-photo-row">
            @if (photoPath != null)
            {
                <img src="@photoPath" class="profile-avatar" alt="Profile photo" />
            }
            else
            {
                <div class="profile-avatar-placeholder">@initials</div>
            }
            <div>
                <p class="profile-photo-name mb-0">@(Model.Profile.FullName ?? "Your Name")</p>
                <p class="profile-photo-email">@Model.Email</p>
                <form asp-action="UploadPhoto" method="post" enctype="multipart/form-data" class="d-inline-flex align-items-center gap-2 mt-1">
                    @Html.AntiForgeryToken()
                    <input type="file" name="photo" accept=".jpg,.jpeg,.png,.webp"
                           class="form-control form-control-sm" style="width:auto;font-size:.78rem;" />
                    <button type="submit" class="btn btn-sm btn-outline-secondary">Update Photo</button>
                </form>
            </div>
        </div>

        <form id="infoForm">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-sm-6">
                    <label class="form-label">Full Name</label>
                    <div class="field-skeleton-wrap" id="fullNameWrap">
                        <input name="fullName" id="fullNameInput" class="form-control" placeholder="e.g. Alex Johnson"
                               value="@Model.Profile.FullName" />
                    </div>
                </div>
                <div class="col-sm-6">
                    <label class="form-label">Display Name <span class="text-muted fw-normal">(shown in navbar)</span></label>
                    <input name="displayName" class="form-control" placeholder="e.g. Alex"
                           value="@Model.Profile.DisplayName" />
                </div>
                <div class="col-sm-3">
                    <label class="form-label">Age</label>
                    <input name="age" type="number" min="16" max="99" class="form-control"
                           placeholder="e.g. 21" value="@Model.Profile.Age" />
                </div>
                <div class="col-sm-3">
                    <label class="form-label">Country</label>
                    <input name="country" class="form-control" placeholder="e.g. United States"
                           value="@Model.Profile.Country" />
                </div>
                <div class="col-sm-6">
                    <label class="form-label">Email <span class="text-muted fw-normal">(from account)</span></label>
                    <input class="form-control" value="@Model.Email" disabled />
                </div>
                <div class="col-sm-6">
                    <label class="form-label">Phone Number <span class="text-muted fw-normal">(optional)</span></label>
                    <input name="phoneNumber" class="form-control" placeholder="e.g. +1 555 123 4567"
                           value="@Model.Profile.PhoneNumber" />
                </div>
                <div class="col-sm-6">
                    <label class="form-label">GitHub Username <span class="text-muted fw-normal">(optional)</span></label>
                    <input name="githubUsername" class="form-control" placeholder="e.g. octocat"
                           value="@Model.Profile.GitHubUsername" />
                </div>
            </div>
            <div class="mt-3 d-flex align-items-center">
                <button type="submit" class="btn btn-dark px-4" id="saveInfoBtn">Save Info</button>
                <span class="save-indicator" id="infoSaveIndicator">Saved &#10003;</span>
            </div>
        </form>
    </div>

    <!-- ── Public Profile Link ── -->
    <div class="form-card mb-3">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <p class="form-section-title mb-1">Public Profile</p>
                <p class="text-muted mb-0" style="font-size:.82rem">Share a read-only link with name, skills, target roles, and stats. No resumes, cover letters, or email are ever shown.</p>
            </div>
            <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" role="switch" id="publicProfileToggle"
                       @(Model.Profile.IsPublic ? "checked" : "") style="width:2.5em;height:1.3em;cursor:pointer;">
            </div>
        </div>
        <div id="publicLinkRow" class="d-flex align-items-center gap-2 mt-3 flex-wrap @(Model.Profile.IsPublic ? "" : "d-none")">
            <input type="text" class="form-control" id="publicLinkInput" readonly
                   style="font-size:.82rem;max-width:420px;"
                   value="@(Model.Profile.PublicSlug != null ? Url.Action("Public", "Profile", new { slug = Model.Profile.PublicSlug }, Context.Request.Scheme) : "")" />
            <button type="button" class="btn btn-sm btn-outline-secondary" id="copyPublicLinkBtn">Copy</button>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="regenLinkBtn">Regenerate Link</button>
            <span class="save-indicator" id="publicLinkIndicator">Copied &#10003;</span>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Profile.GitHubUsername))
    {
        <!-- ── GitHub Projects ── -->
        <div class="form-card mb-3">
            <div class="d-flex align-items-center justify-content-between mb-2">
                <p class="form-section-title mb-0">Projects</p>
                <a href="https://github.com/@Model.Profile.GitHubUsername" target="_blank" rel="noopener"
                   class="text-muted" style="font-size:.78rem">@@@Model.Profile.GitHubUsername on GitHub &rarr;</a>
            </div>
            @if (Model.GitHubRepos == null)
            {
                <p class="text-muted mb-0" style="font-size:.82rem">Couldn't load repos for this username right now.</p>
            }
            else if (!Model.GitHubRepos.Any())
            {
                <p class="text-muted mb-0" style="font-size:.82rem">No public repos found for this username.</p>
            }
            else
            {
                <div class="doc-list">
                    @foreach (var repo in Model.GitHubRepos)
                    {
                        <a class="doc-row" href="@repo.Url" target="_blank" rel="noopener" style="text-decoration:none;color:inherit;">
                            <div class="doc-info">
                                <div class="doc-filename">@repo.Name</div>
                                <div class="doc-meta">
                                    @(string.IsNullOrWhiteSpace(repo.Description) ? "No description" : repo.Description)
                                </div>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(repo.Language))
                            {
                                <span class="active-label">@repo.Language</span>
                            }
                            <span class="text-muted" style="font-size:.78rem">&#9733; @repo.Stars</span>
                        </a>
                    }
                </div>
            }
        </div>
    }

    <!-- ── Application Stats ── -->
    <div class="form-card mb-3">
        <p class="form-section-title">Application Stats</p>
        <div class="row g-2 mb-2">
            <div class="col-6 col-sm-4 col-md-2">
                <div class="mini-stat">
                    <div class="mini-stat-num" style="color:var(--primary)">@Model.TotalApplications</div>
                    <div class="mini-stat-label">Total</div>
                </div>
            </div>
            @foreach (var entry in Model.StatusCounts)
            {
                var colorClass = entry.Key switch
                {
                    InternTrackAI.Models.Enums.ApplicationStatus.Saved      => "mini-stat-saved",
                    InternTrackAI.Models.Enums.ApplicationStatus.Applied    => "mini-stat-applied",
                    InternTrackAI.Models.Enums.ApplicationStatus.Interview  => "mini-stat-interview",
                    InternTrackAI.Models.Enums.ApplicationStatus.Offer      => "mini-stat-offer",
                    InternTrackAI.Models.Enums.ApplicationStatus.Rejected   => "mini-stat-rejected",
                    _ => ""
                };
                <div class="col-6 col-sm-4 col-md-2">
                    <div class="mini-stat">
                        <div class="mini-stat-num @colorClass">@entry.Value</div>
                        <div class="mini-stat-label">@entry.Key</div>
                    </div>
                </div>
            }
            <div class="col-6 col-sm-4 col-md-2">
                <div class="mini-stat">
                    <div class="mini-stat-num mini-stat-offer">@Model.SuccessRate<span style="font-size:1rem;font-weight:600">%</span></div>
                    <div class="mini-stat-label">Success Rate</div>
                </div>
            </div>
        </div>
        <p class="text-muted mb-0" style="font-size:.75rem">Success rate = Offers &divide; Total applications</p>
    </div>

    <!-- ── Skills ── -->
    <div class="form-card mb-3">
        <div class="d-flex align-items-center mb-1">
            <p class="form-section-title mb-0">Skills</p>
            <span class="save-indicator" id="skillsSaveIndicator">Saved &#10003;</span>
        </div>
        <p class="text-muted mb-3" style="font-size:.82rem">Add your technical and professional skills. These are used as context during AI resume matching. Changes save automatically.</p>
        <div class="field-skeleton-wrap" id="skillsWrap">
            <input type="hidden" id="skillsJsonInput" />
            <div class="tag-cloud" id="skillsCloud">
                <div class="tag-input-row">
                    <input type="text" class="tag-text-input" id="skillsText" placeholder="e.g. Python" />
                    <button type="button" class="tag-add-btn" id="skillsAdd">Add</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Target Roles ── -->
    <div class="form-card mb-3">
        <div class="d-flex align-items-center mb-1">
            <p class="form-section-title mb-0">Target Roles</p>
            <span class="save-indicator" id="rolesSaveIndicator">Saved &#10003;</span>
        </div>
        <p class="text-muted mb-3" style="font-size:.82rem">Search common internship roles or type your own. These help the AI give more relevant scoring and advice. Changes save automatically.</p>
        <div class="field-skeleton-wrap" id="rolesWrap">
            <input type="hidden" id="rolesJsonInput" />
            <div class="tag-cloud" id="rolesCloud">
                <div class="tag-input-row">
                    <div class="role-combobox-wrap">
                        <input type="text" class="tag-text-input" id="rolesText" placeholder="Search or type a role..." autocomplete="off" style="flex:0 1 260px" />
                        <ul class="role-combobox-list" id="rolesComboList"></ul>
                    </div>
                    <button type="button" class="tag-add-btn" id="rolesAdd">Add</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Cover Letters ── -->
    <div class="form-card mb-3">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <p class="form-section-title mb-0">Cover Letters</p>
            <span class="text-muted" style="font-size:.75rem">@Model.CoverLetters.Count version(s)</span>
        </div>

        @if (Model.CoverLetters.Any())
        {
            <div class="doc-list mb-3">
                @foreach (var cl in Model.CoverLetters)
                {
                    <div class="doc-row @(cl.IsActive ? "doc-active" : "")">
                        <span class="doc-version-badge">v@(cl.VersionNumber)</span>
                        <div class="doc-info">
                            <div class="doc-filename">@cl.OriginalFileName</div>
                            <div class="doc-meta">
                                @cl.UploadedAt.ToLocalTime().ToString("MMM d, yyyy") &middot;
                                @((cl.FileSize / 1024.0).ToString("F0")) KB
                            </div>
                        </div>
                        @if (cl.IsActive)
                        {
                            <span class="active-label">Active</span>
                        }
                        else
                        {
                            <form asp-action="SetActiveCoverLetter" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@cl.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-primary" style="font-size:.72rem;padding:.2rem .6rem;">Set Active</button>
                            </form>
                        }
                        <a asp-action="DownloadCoverLetter" asp-route-id="@cl.Id"
                           class="btn btn-sm btn-outline-secondary" style="font-size:.72rem;padding:.2rem .6rem;">Download</a>
                        <form asp-action="DeleteCoverLetter" method="post" class="d-inline"
                              onsubmit="return confirm('Delete Cover Letter v@(cl.VersionNumber)? This cannot be undone.')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@cl.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger" style="font-size:.72rem;padding:.2rem .6rem;">Delete</button>
                        </form>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted mb-3" style="font-size:.875rem">No cover letters uploaded yet.</p>
        }

        <form asp-action="UploadCoverLetter" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <input type="file" name="coverLetter" accept=".pdf"
                       class="form-control" style="width:auto;font-size:.875rem;" />
                <button type="submit" class="btn btn-dark">Upload New Cover Letter</button>
                <span class="text-muted" style="font-size:.75rem">PDF only &middot; Max 5 MB</span>
            </div>
        </form>
    </div>

    <!-- ── AI Resume Score ── -->
    <div class="form-card mb-3">
        <p class="form-section-title">AI Resume Score</p>
        <p class="text-muted mb-3" style="font-size:.82rem">
            Score your active resume using GPT-4o mini. Get an overall quality score, strengths, and specific improvement suggestions.
        </p>

        @if (!Model.Resumes.Any(r => r.IsActive))
        {
            <p class="text-muted" style="font-size:.875rem">
                Upload a resume and set it as active to enable scoring.
            </p>
        }
        else
        {
            <form asp-action="ScoreResume" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-dark px-4" id="scoreBtn">
                    Score My Resume
                </button>
                <span class="ms-2 text-muted" style="font-size:.78rem">Powered by GPT-4o mini</span>
            </form>

            @if (Model.ScoreResult != null)
            {
                if (Model.ScoreResult.Success)
                {
                    <div class="match-score-card mt-3">
                        <div class="match-score-left">
                            <div class="score-ring-wrap">
                                <svg class="score-svg" viewBox="0 0 140 140">
                                    <circle class="score-track" cx="70" cy="70" r="54" />
                                    <circle class="score-fill score-fill--@scoreColor"
                                            cx="70" cy="70" r="54"
                                            style="--ring-offset:@scoreDashOff;stroke-dasharray:@CircStr" />
                                </svg>
                                <div class="score-label">
                                    <span class="score-number">@Model.ScoreResult.Score</span>
                                    <span class="score-unit">%</span>
                                </div>
                            </div>
                        </div>
                        <div class="match-score-right">
                            <p class="match-score-title">Resume Quality Score</p>
                            <p class="match-summary">@Model.ScoreResult.Summary</p>
                        </div>
                    </div>

                    <div class="row g-3 mt-0">
                        @if (Model.ScoreResult.Strengths.Any())
                        {
                            <div class="col-md-6">
                                <div class="form-card">
                                    <p class="form-section-title section-title--strengths">Strengths</p>
                                    <ul class="match-strengths-list">
                                        @foreach (var s in Model.ScoreResult.Strengths)
                                        { <li>@s</li> }
                                    </ul>
                                </div>
                            </div>
                        }
                        @if (Model.ScoreResult.Improvements.Any())
                        {
                            <div class="col-md-6">
                                <div class="form-card">
                                    <p class="form-section-title section-title--improvements">Improvements</p>
                                    <ul class="match-strengths-list">
                                        @foreach (var imp in Model.ScoreResult.Improvements)
                                        { <li>@imp</li> }
                                    </ul>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="match-error-banner mt-3">@Model.ScoreResult.Error</div>
                }
            }
        }
    </div>

</div>

@section Scripts {
    <script>
    (function () {

        const ROLE_PRESETS = [
            "Software Engineering Intern", "Backend Developer Intern", "Frontend Developer Intern",
            "Full-Stack Developer Intern", "Data Science Intern", "Machine Learning Intern",
            "DevOps Intern", "Cloud Engineering Intern", "Mobile Developer Intern", "QA Engineer Intern",
            "Cybersecurity Intern", "Product Manager Intern", "Data Engineer Intern",
            "iOS Developer Intern", "Android Developer Intern"
        ];

        const antiForgeryToken = document.querySelector('#infoForm input[name="__RequestVerificationToken"]')?.value || '';

        function postForm(url, fields) {
            const body = new URLSearchParams({ __RequestVerificationToken: antiForgeryToken, ...fields });
            return fetch(url, { method: 'POST', body, headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(r => r.json());
        }

        function flashSaveIndicator(el) {
            if (!el) return;
            el.classList.add('show');
            clearTimeout(el.__hideTimer);
            el.__hideTimer = setTimeout(() => el.classList.remove('show'), 2000);
        }

        // ── Tag input helper ─────────────────────────────
        function initTagInput(cloudId, hiddenId, textId, addBtnId, initialValues, opts) {
            opts = opts || {};
            const cloud   = document.getElementById(cloudId);
            const hidden  = document.getElementById(hiddenId);
            const textEl  = document.getElementById(textId);
            const addBtn  = document.getElementById(addBtnId);
            let values    = Array.isArray(initialValues) ? [...initialValues] : [];

            function render() {
                cloud.querySelectorAll('.tag-item').forEach(t => t.remove());
                const inputRow = cloud.querySelector('.tag-input-row');
                values.forEach((val, i) => {
                    const tag = document.createElement('span');
                    tag.className = 'tag-item';
                    tag.innerHTML = `${escHtml(val)} <button type="button" data-i="${i}" aria-label="Remove">&times;</button>`;
                    cloud.insertBefore(tag, inputRow);
                });
                hidden.value = JSON.stringify(values);
            }

            function persist() {
                render();
                if (opts.onChange) opts.onChange(values);
            }

            cloud.addEventListener('click', e => {
                const btn = e.target.closest('button[data-i]');
                if (btn) { values.splice(parseInt(btn.dataset.i), 1); persist(); }
            });

            function add(value) {
                const v = (value !== undefined ? value : textEl.value).trim();
                if (v && !values.includes(v)) { values.push(v); persist(); }
                textEl.value = '';
                textEl.focus();
                if (opts.onAfterAdd) opts.onAfterAdd();
            }

            addBtn.addEventListener('click', () => add());
            textEl.addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); add(); } });

            render();
            return { values: () => values, add, render };
        }

        function escHtml(s) {
            return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        // ── Skills: tag input with AJAX autosave ─────────
        const skillsApi = initTagInput('skillsCloud', 'skillsJsonInput', 'skillsText', 'skillsAdd',
            @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Skills)),
            {
                onChange: (values) => {
                    postForm('/Profile/SaveSkills', { skillsJson: JSON.stringify(values) })
                        .then(res => { if (res.success) flashSaveIndicator(document.getElementById('skillsSaveIndicator')); });
                }
            });

        // ── Target roles: tag input + searchable combobox with AJAX autosave ──
        const rolesApi = initTagInput('rolesCloud', 'rolesJsonInput', 'rolesText', 'rolesAdd',
            @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TargetRoles)),
            {
                onChange: (values) => {
                    postForm('/Profile/SaveTargetRoles', { targetRolesJson: JSON.stringify(values) })
                        .then(res => { if (res.success) flashSaveIndicator(document.getElementById('rolesSaveIndicator')); });
                },
                onAfterAdd: () => closeComboList()
            });

        const rolesText = document.getElementById('rolesText');
        const comboList = document.getElementById('rolesComboList');

        function closeComboList() { comboList.classList.remove('open'); comboList.innerHTML = ''; }

        function renderComboList(filter) {
            const taken = rolesApi.values();
            const matches = ROLE_PRESETS.filter(r =>
                !taken.includes(r) && r.toLowerCase().includes(filter.toLowerCase()));

            comboList.innerHTML = '';
            if (matches.length === 0) {
                comboList.innerHTML = '<li class="role-combobox-empty">No presets match — press Enter to add as a custom role</li>';
            } else {
                matches.forEach(m => {
                    const li = document.createElement('li');
                    li.className = 'role-combobox-option';
                    li.textContent = m;
                    li.addEventListener('mousedown', e => { e.preventDefault(); rolesApi.add(m); closeComboList(); });
                    comboList.appendChild(li);
                });
            }
            comboList.classList.add('open');
        }

        rolesText.addEventListener('input', () => renderComboList(rolesText.value));
        rolesText.addEventListener('focus', () => renderComboList(rolesText.value));
        rolesText.addEventListener('blur', () => setTimeout(closeComboList, 120));

        // ── Personal Info: AJAX save with shake-on-required validation ──
        const infoForm     = document.getElementById('infoForm');
        const fullNameInput = document.getElementById('fullNameInput');
        const saveInfoBtn   = document.getElementById('saveInfoBtn');

        infoForm.addEventListener('submit', e => {
            e.preventDefault();

            if (!fullNameInput.value.trim()) {
                shakeField(fullNameInput, 'This field is required');
                return;
            }
            clearFieldError(fullNameInput);

            const fd = new FormData(infoForm);
            saveInfoBtn.disabled = true;
            postForm('/Profile/SaveInfo', Object.fromEntries(fd.entries()))
                .then(res => {
                    saveInfoBtn.disabled = false;
                    if (res.success) {
                        flashSaveIndicator(document.getElementById('infoSaveIndicator'));
                        showAppToast('success', 'Profile info saved.');
                    } else {
                        shakeField(fullNameInput, res.error || 'This field is required');
                    }
                })
                .catch(() => { saveInfoBtn.disabled = false; showAppToast('error', 'Could not save — try again.'); });
        });

        // ── Resume analyze with AI (Section 1a) ──
        const analyzeBtn      = document.getElementById('analyzeBtn');
        const analyzeBtnLabel = document.getElementById('analyzeBtnLabel');
        const analyzeError    = document.getElementById('analyzeError');

        if (analyzeBtn) {
            analyzeBtn.addEventListener('click', () => {
                analyzeBtn.disabled = true;
                analyzeBtnLabel.innerHTML = '<span class="spinner-border spinner-border-sm analyze-spinner"></span> Analyzing...';
                analyzeError.style.display = 'none';

                ['fullNameWrap', 'skillsWrap', 'rolesWrap'].forEach(id => {
                    const wrap = document.getElementById(id);
                    const skel = document.createElement('div');
                    skel.className = 'skeleton-line';
                    wrap.appendChild(skel);
                    wrap.classList.add('skeleton-active');
                });

                postForm('/Profile/AnalyzeResume', {})
                    .then(res => {
                        ['fullNameWrap', 'skillsWrap', 'rolesWrap'].forEach(id => {
                            const wrap = document.getElementById(id);
                            wrap.querySelector('.skeleton-line')?.remove();
                            wrap.classList.remove('skeleton-active');
                        });
                        analyzeBtn.disabled = false;
                        analyzeBtnLabel.textContent = 'Analyze with AI';

                        if (!res.success) {
                            analyzeError.textContent = res.error || 'Could not analyze resume.';
                            analyzeError.style.display = 'block';
                            return;
                        }

                        let filledSomething = false;

                        if (res.fullName && !fullNameInput.value.trim()) {
                            fullNameInput.value = res.fullName;
                            filledSomething = true;
                        }
                        (res.skills || []).forEach(s => { skillsApi.add(s); filledSomething = true; });
                        (res.targetRoles || []).forEach(r => { rolesApi.add(r); filledSomething = true; });

                        if (filledSomething) {
                            showAppToast('success', 'Profile auto-filled from your resume. Review and click Save Info to keep the name.');
                        } else {
                            showAppToast('info', 'No new details found to fill in.');
                        }
                    })
                    .catch(() => {
                        ['fullNameWrap', 'skillsWrap', 'rolesWrap'].forEach(id => {
                            const wrap = document.getElementById(id);
                            wrap.querySelector('.skeleton-line')?.remove();
                            wrap.classList.remove('skeleton-active');
                        });
                        analyzeBtn.disabled = false;
                        analyzeBtnLabel.textContent = 'Analyze with AI';
                        analyzeError.textContent = 'Request failed. Check your connection and try again.';
                        analyzeError.style.display = 'block';
                    });
            });
        }

        // Loading state for score button
        const scoreBtn = document.getElementById('scoreBtn');
        if (scoreBtn) {
            scoreBtn.closest('form').addEventListener('submit', () => {
                scoreBtn.disabled = true;
                scoreBtn.innerHTML =
                    '<span class="spinner-border spinner-border-sm" style="width:14px;height:14px;border-width:2px"></span> Scoring...';
            });
        }

        // Scroll to score result if present
        const scoreCard = document.querySelector('.match-score-card');
        if (scoreCard) {
            setTimeout(() => scoreCard.scrollIntoView({ behavior: 'smooth', block: 'start' }), 200);
        }

        // ── Public Profile Link ──────────────────────────
        const publicToggle  = document.getElementById('publicProfileToggle');
        const publicLinkRow = document.getElementById('publicLinkRow');
        const publicLinkInput = document.getElementById('publicLinkInput');
        const copyLinkBtn   = document.getElementById('copyPublicLinkBtn');
        const regenLinkBtn  = document.getElementById('regenLinkBtn');
        const publicLinkIndicator = document.getElementById('publicLinkIndicator');

        publicToggle?.addEventListener('change', () => {
            postForm('/Profile/TogglePublic', { isPublic: publicToggle.checked })
                .then(res => {
                    if (!res.success) return;
                    if (res.url) publicLinkInput.value = res.url;
                    publicLinkRow.classList.toggle('d-none', !res.isPublic);
                });
        });

        copyLinkBtn?.addEventListener('click', () => {
            if (!publicLinkInput.value) return;
            navigator.clipboard.writeText(publicLinkInput.value).then(() => flashSaveIndicator(publicLinkIndicator));
        });

        regenLinkBtn?.addEventListener('click', () => {
            postForm('/Profile/RegenerateLink', {})
                .then(res => {
                    if (!res.success) return;
                    publicLinkInput.value = res.url;
                    flashSaveIndicator(publicLinkIndicator);
                });
        });

    })();
    </script>
}
