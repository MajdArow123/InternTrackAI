<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InternTrackAI</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/InternTrackAI.styles.css" asp-append-version="true" />
    <script>
    (function(){var t=localStorage.getItem('theme')||'light';document.documentElement.setAttribute('data-theme',t);})();
    </script>
</head>
<body>
    @{
        var ctrl   = ViewContext.RouteData.Values["controller"]?.ToString();
        var action = ViewContext.RouteData.Values["action"]?.ToString();
        bool IsActive(string c, string a = "Index") =>
            string.Equals(ctrl, c, StringComparison.OrdinalIgnoreCase) &&
            string.Equals(action, a, StringComparison.OrdinalIgnoreCase);
    }

    <header>
        <nav class="navbar navbar-expand-sm site-nav">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-dot"></span>
                    InternTrackAI
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between align-items-center">
                    <ul class="navbar-nav flex-grow-1 gap-1 ms-2">
                        <li class="nav-item">
                            <a class="nav-link @(IsActive("Home","Index") ? "active" : "")"
                               asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(IsActive("Home","Dashboard") ? "active" : "")"
                               asp-area="" asp-controller="Home" asp-action="Dashboard">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(IsActive("JobApplications") ? "active" : "")"
                               asp-controller="JobApplications" asp-action="Index">Applications</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(IsActive("CoverLetter","Generate") ? "active" : "")"
                               asp-controller="CoverLetter" asp-action="Generate">Cover Letter</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(IsActive("Profile") ? "active" : "")"
                               asp-controller="Profile" asp-action="Index">Profile</a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center gap-2">
                        <button id="theme-toggle" class="dark-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
                            <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                            </svg>
                            <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                            </svg>
                        </button>
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="anim-fade-up" style="animation-duration:.4s;animation-delay:.05s">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">
            &copy; 2026 InternTrackAI &mdash; built for students.
            <span class="kbd-hint-footer">Press <kbd class="kbd-inline">?</kbd> for keyboard shortcuts</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @if (TempData["Toast"] is string toastData)
    {
        var parts     = toastData.Split('|', 2);
        var toastType = parts.Length > 0 ? parts[0] : "info";
        var toastMsg  = parts.Length > 1 ? parts[1] : "";
        <div id="app-toast" class="app-toast app-toast-@toastType" role="alert" aria-live="polite">
            <span class="app-toast-dot"></span>
            <span class="app-toast-msg">@toastMsg</span>
            <button type="button" class="app-toast-close" onclick="dismissToast()" aria-label="Dismiss">&#215;</button>
        </div>
        <script>
        window.addEventListener('DOMContentLoaded', function () {
            var t = document.getElementById('app-toast');
            if (t) {
                requestAnimationFrame(function () { t.classList.add('app-toast-show'); });
                setTimeout(dismissToast, 4500);
            }
        });
        function dismissToast() {
            var t = document.getElementById('app-toast');
            if (t) { t.classList.remove('app-toast-show'); setTimeout(function () { t.remove(); }, 280); }
        }
        </script>
    }

    <!-- Keyboard Shortcuts Modal -->
    <div id="kbd-modal" class="kbd-modal-overlay" aria-hidden="true" role="dialog" aria-label="Keyboard shortcuts">
        <div class="kbd-modal">
            <div class="kbd-modal-header">
                <span class="kbd-modal-title">Keyboard Shortcuts</span>
                <button class="kbd-modal-close" id="kbd-close" aria-label="Close">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="kbd-modal-body">
                <div class="kbd-row"><span class="kbd">N</span><span>New Application</span></div>
                <div class="kbd-row"><span class="kbd">D</span><span>Dashboard</span></div>
                <div class="kbd-row"><span class="kbd">C</span><span>Cover Letter</span></div>
                <div class="kbd-row"><span class="kbd">P</span><span>Profile</span></div>
                <div class="kbd-row"><span class="kbd">S</span><span>Focus Search</span></div>
                <div class="kbd-row"><span class="kbd">?</span><span>Show Shortcuts</span></div>
                <div class="kbd-row"><span class="kbd">Esc</span><span>Close</span></div>
            </div>
        </div>
    </div>

    <script>
    (function () {
        // Dark mode toggle
        var toggle = document.getElementById('theme-toggle');
        if (toggle) {
            toggle.addEventListener('click', function () {
                var curr = document.documentElement.getAttribute('data-theme');
                var next = curr === 'dark' ? 'light' : 'dark';
                document.documentElement.setAttribute('data-theme', next);
                localStorage.setItem('theme', next);
            });
        }

        // Keyboard shortcuts
        var kbdModal = document.getElementById('kbd-modal');
        function openKbd() { kbdModal.classList.add('active'); kbdModal.setAttribute('aria-hidden','false'); }
        function closeKbd() { kbdModal.classList.remove('active'); kbdModal.setAttribute('aria-hidden','true'); }

        document.getElementById('kbd-close')?.addEventListener('click', closeKbd);
        kbdModal?.addEventListener('click', function(e) { if (e.target === kbdModal) closeKbd(); });

        function isTyping() {
            var el = document.activeElement;
            return el && (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA' || el.tagName === 'SELECT' || el.isContentEditable);
        }

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') { closeKbd(); return; }
            if (isTyping()) return;
            if (e.ctrlKey || e.metaKey || e.altKey) return;
            switch (e.key) {
                case '?': e.preventDefault(); openKbd(); break;
                case 'n': case 'N': window.location.href = '/JobApplications/Create'; break;
                case 'd': case 'D': window.location.href = '/Home/Dashboard'; break;
                case 'c': case 'C': window.location.href = '/CoverLetter/Generate'; break;
                case 'p': case 'P': window.location.href = '/Profile'; break;
                case 's': case 'S':
                    var s = document.querySelector('input[name="search"]');
                    if (s) { e.preventDefault(); s.focus(); }
                    break;
            }
        });
    })();
    </script>
</body>
</html>
